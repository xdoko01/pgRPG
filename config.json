{
	"paths" : {
		"model_path" : "pyrpg/resources/models/",
		"map_path" :  "pyrpg/resources/maps/",
		"quest_path" :  "pyrpg/resources/quests/",
		"font_path" :  "pyrpg/resources/fonts/"
	},	

	"display" : {
		"tile_res" : [64, 64],
		"resolution" : [1024, 768],
		"fullscreen" : false,
		"fps" : 30,
		"show_fps" : true,
		"collision_map" : false,
		"raycasting" : false,
		"window_title": "PyRPG",
		"font_file" : "my_courier.ttf",
		"font_size" : 16
	},

	"sound" : {
		"sound_volume": 0,
		"music_volume" : 0		
	},

	"game" : {
		"starting_quest": "main_quest"
	},

	"console" : {
		"global" : {
			"cli_module" : "pyrpg.core.engine",	
			"animation": ["TOP", 2000],
			"layout" : "INPUT_BOTTOM",
			"padding" : [10,10,20,20],
			"bck_color" : [125,125,125],
			"bck_image" : "pyrpg/resources/images/quake.png",
			"bck_image_resize" : true,
			"bck_alpha" : 150,
			"welcome_msg" : "Sample 1: Full feature console + top animation with 2s timing\n***************\nType 'exit' to quit\nType 'help'/'?' for help\nType '? shell' for examples of python commands",
			"welcome_msg_color" : [0,255,0]
			},
		"header" : {
			"text" : "pyRPG Console v0.1 | {} | ",
			"text_params" : ["cons_get_info_header"],
			"layout" : ["SCROLL_LEFT_CONTINUOUS", 0, 2],
			"padding" :[10,10,10,10],
			"font_file" : "pyrpg/resources/fonts/IBMPlexMono-Regular.ttf",
			"font_size" : 12,
			"font_antialias" : true,
			"font_color" : [255,255,255],
			"bck_color" : [255,0,0],
			"bck_image" : "pyrpg/resources/images/quake.png",
			"bck_image_resize" : true,
			"bck_alpha" : 100
			},
		"output" : {
			"padding" : [10,10,10,10],
			"font_file" : "pyrpg/resources/fonts/JackInput.ttf",
			"font_size" : 16,
			"font_antialias" : true,
			"font_color" : [255,255,255],
			"font_bck_color" : [55,0,0],
			"bck_color" : [55,0,0],
			"bck_alpha" : 120,
			"buffer_size" : 100,
			"display_lines" : 20,
			"display_columns" : 100
			},
		"input" : {
			"padding" : [10,10,10,10],
			"font_file" : "pyrpg/resources/fonts/JackInput.ttf",
			"font_size" : 16,
			"font_antialias" : true,
			"font_color" : [255,0,0],
			"bck_color" : [0,255,0],
			"bck_alpha" : 75,
			"prompt" : ">>>",
			"max_string_length" : 10,
			"repeat_keys_initial_ms" : 400,
			"repeat_keys_interval_ms" :35
			},
		"footer" : {						
			"text" : "{}",
			"text_params" : ["cons_get_info_footer"],
			"layout" : ["TEXT_RIGHT"],
			"padding" : [10,10,10,10],
			"font_file" : "pyrpg/resources/fonts/IBMPlexMono-Regular.ttf",
			"font_size" : 10,
			"font_antialias" : true,
			"font_color" : [255,255,255],
			"bck_color" : [0,0,0],
			"bck_image_resize" : true,
			"bck_alpha" : 100
			}
		},

	"logging" :	{
		"version" : 1.0,
		"disable_existing_loggers": true,

		"formatters": {
			"simple": {
				"format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
			},
			"extra": {
				"format":"%(asctime)-2s %(levelname)-6s %(name)-30s %(filename)-15s %(funcName)-18s %(lineno)-6s %(message)s",
				"datefmt":"%m-%d %H:%M:%S"
			}
		},
	
		"handlers": {
			"console": {
				"class": "logging.StreamHandler",
				"level": "DEBUG",
				"formatter": "extra",
				"stream": "ext://sys.stdout"
			}       
		},
	
		"loggers" : {
			"console_logger" : {
				"level" : "DEBUG",
				"handlers" : ["console"]
			}
		},
		
		"root" : {
			"level" : "DEBUG",
			"handlers" : ["console"]
		}	
	}
}