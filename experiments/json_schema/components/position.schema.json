{
	"$id": "position.schema.json",
	"$schema": "https://json-schema.org/draft-07/schema",
	"description": "Schema validating position component.",
	"title": "Position Component",

	"required": [ "type", "params"],
	"properties": {
		"type": {
			"enum": [ "position:Position" ]
		},
		"params": {
			"type": "object",
			"required": ["x", "y"],
			"properties": {
				"x" : {
					"description": "X-coordinate",
					"type": "number",
					"minimum": 0
				},
				"y": {
					"description": "Y-coordinate",
					"type": "number",
					"minimum": 0
				}
			}
		}
	}
}
