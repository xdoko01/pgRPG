{
	"$id": "movable.schema.json",
	"$schema": "https://json-schema.org/draft-07/schema",
	"description": "Schema validating movable component.",
	"title": "Movable Component",

	"required": [ "type", "params"],
	"properties": {
		"type": {
			"enum": [ "movable:Movable" ]
		},
		"params": {
			"type": "object",
			"required": ["velocity"],
			"additionalProperties": false,
			"properties": {
				"velocity" : {
					"description": "Speed of the entity.",
					"type": "number",
					"minimum": 0
				},
				"accelerate": {
					"description": "Acceleration rate of the entity.",
					"type": "number" 
				}
			}
		}
	}
}
