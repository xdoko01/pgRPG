				],
	
				"TELEPORTATION" : [
				],

				"ITEM_PICKUP" : [
				],

				"WEARABLE_WEARED" : [
				],

				"WEAPON_ARMED" : [
				]

			},

			"after_steps" : [
				{
					"erase" : ""
				}
			]
		}
	}
