					"components" : [

						/////////////////////////////////////////////////////////
						// TEST 2 - Movement command based on movement directions 
						// - diagonal is supported but must be mapped on one key
						// - single command / multiple direction upon keypress
						/////////////////////////////////////////////////////////
						{"type" : "Controllable", "params" :  {"key_profile" : "default",
							"control_cmds" : {
								"left" : [["new_move_noadd", {"moves" : ["left", "up"]}]],
								"right": [["new_move_noadd", {"moves" : ["right", "down"]}]],
								"up" : [["new_move_noadd", {"moves" : ["up", "right"]}]],
								"down" : [["new_move_noadd", {"moves" : ["down", "left"]}]],
								"attack" : [["none", {}]]}
							}
						},

						{"type" : "Position", "params" : {"x" : 250, "y" : 250, "map" : "test_arena_sand"}},
						{"type" : "Movable", "params" :  {"velocity" : 100}},
						{"type" : "Camera", "params" : {"always_center": false, "screen_pos_x" : 0, "screen_pos_y" : 0, "screen_width" : 640, "screen_height" : 480}}
					]
				}
			],

