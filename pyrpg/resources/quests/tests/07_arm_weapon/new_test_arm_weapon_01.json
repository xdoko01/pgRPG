	"description" : "Test new arm weapon processors",
	"objective" : "POC of the new arm weapon system",
	"init_phase" : "phase01",

	"processors" : [
		// For commands
		["GenerateCommandFromInputProcessor", {}],
		["GenerateCommandFromBrainProcessor", {}],
		["PerformCommandProcessor", {}],

		// For movement
		["PerformMovementProcessor", {}],

		// For animation
		["PerformMovementAnimationProcessor", {}],
		["PerformIdleAnimationProcessor", {}],
		["PerformFrameUpdateProcessor", {}],

		// For collisions
		["GenerateEntityCollisionsProcessor", {}],
		["ResolveEntityCollisionsExProcessor", {}],

		// For pickup
		["GeneratePickupProcessor", {}],
		["PerformPickupProcessor", {}],

		// For Arming of a Weapon
		["GenerateArmWeaponProcessor", {}],
		["PerformArmWeaponProcessor", {}],

		// For displaying
		["UpdateCameraOffsetProcessor", {}],
		["RenderBackgroundProcessor", {}],
		["RenderCameraBackgroundProcessor", {}],
		["RenderMapProcessor", {}],
		["RenderWorldProcessor", {}],
		["RenderModelWorldProcessor", {}],
		["RenderDebugProcessor", {}],

		// For events processing - display the dialog on the start of the quest - after first game screen is generated
		["GameEventsExProcessor", {"process" : ["QUEST_START", "WEAPON_ARMED"]}],

		// For clearing of processing of movements and collisions and pickups
		["RemoveFlagDoMoveProcessor", {}],

		["RemoveFlagHasCollidedProcessor", {}],

		["RemoveFlagIsAboutToPickEntityProcessor", {}],
		["RemoveFlagHasPickedProcessor", {}],
		["RemoveFlagWasPickedByProcessor", {}],

		["RemoveFlagIsAboutToArmWeaponProcessor", {}],
		["RemoveFlagHasArmedWeaponProcessor", {}],
		["RemoveFlagWasArmedAsWeaponByProcessor", {}]

