{
	"id" : "new_test_render_02",
	"name" : "Render Map Test",
	"description" : "Test new render processors",
	"objective" : "POC of the new render system - display scrollable map",
	"init_phase" : "phase01",

	"processors" : [
		// For commands
		["new.command_system.new_generate_command_from_input_processor", "NewGenerateCommandFromInputProcessor", {}],
		["new.command_system.new_perform_command_processor", "NewPerformCommandProcessor", {}],

		// For movement
		["new.movement_system.new_perform_movement_processor", "NewPerformMovementProcessor", {}],

		// For displaying
		["new.render_system.new_perform_clear_window_processor", "NewPerformClearWindowProcessor", {"clear_color" : [50, 150, 50]}], // clear the game window
		["new.render_system.new_perform_clear_camera_processor", "NewPerformClearCameraProcessor", {"clear_color" : [100, 0, 0]}], // clear all camera surfaces
		["new.render_system.new_perform_scroll_camera_processor", "NewPerformScrollCameraProcessor", {}], // scroll the camera
		["new.render_system.new_perform_render_map_processor", "NewPerformRenderMapProcessor", {}], // display map
		["new.render_system.new_perform_blit_camera_processor", "NewPerformBlitCameraProcessor", {}], // display all cameras on the game window

		// For movement
		["new.movement_system.new_remove_flag_do_move_porcessor", "NewRemoveFlagDoMoveProcessor", {}]
	],

	"phases" : {
		"phase01" :{
			"name" : "Render Map Test - Scrolling", "objective" : "","maps" : ["test_arena_sand"],

			"cleanup" : {"maps" : [], "entities" : []}, "dialogs" : [],

			"entities" : [

				// In order to display anything, entity with Camera and Position must exist
				// Multiple cameras are supported
				{
					"id" : "camera01",
					"templates" : [],
					"components" : [

						// Component to control camera using keyboard
						{"type" : "NewControllable", "params" :  {"key_profile" : "default",
							"control_cmds" : {
								"left" : [["new_move_add", {"moves" : ["left"]}]],
								"right": [["new_move_add", {"moves" : ["right"]}]],
								"up" : [["new_move_add", {"moves" : ["up"]}]],
								"down" : [["new_move_add", {"moves" : ["down"]}]],
								"attack" : null}
							}
						},

						// Without NewMovable component the Camera won't move
						{"type" : "NewMovable", "params" :  {"velocity" : 100}},
						{"type" : "Position", "params" : {"x" : 250, "y" : 250, "map" : "test_arena_sand"}},

						// When moving camera it makes sense to have it always centred
						{"type" : "Camera", "params" : {"always_center": true, "screen_pos_x" : 5, "screen_pos_y" : 5, "screen_width" : 630, "screen_height" : 230}}
					]
				},
				{
					"id" : "camera02",
					"templates" : [],
					"components" : [
						{"type" : "Position", "params" : {"x" : 2000, "y" : 2000, "map" : "test_arena_sand"}},
						{"type" : "Camera", "params" : {"always_center": false, "screen_pos_x" : 5, "screen_pos_y" : 245, "screen_width" : 630, "screen_height" : 230}}
					]
				}
			],

			"event_handling" : {

				"QUEST_START" : [
				],

				"PHASE_START" : [
				],

				"KILL" : [
				],

				"DAMAGE" : [
				],

				"COLLISION" : [
				],
	
				"TELEPORTATION" : [
				],

				"ITEM_PICKUP" : [
				],

				"WEARABLE_WEARED" : [
				],

				"WEAPON_ARMED" : [
				]

			},

			"after_steps" : [
				{
					"erase" : ""
				}
			]
		}
	}
}