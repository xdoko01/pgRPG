			"cleanup" : {"maps" : [], "entities" : []}, "dialogs" : [],

			"entities" : [
				
				// AmmoPack is Factory for generation of arrows
				{
					"id" : "wooden_arrows_pack",
					"templates" : [],
					"components" : [
						{"type" : "ammo_pack:AmmoPack", "params" : {"weapon" : "bow", "type" : "wooden_arrows_pack"}},
						{"type" : "renderable_model:RenderableModel", "params" : {"model" : "wooden_arrows_pack.json"}},
						{
							"type" : "new_factory:NewFactory", 
							"params" : {
								"prescription" : {
									"id" : "wooden_arrow",
									"templates" : [],
									"components" : [
										{"type" : "new_debug:NewDebug", "params" : {}},

										{"type" : "brain:Brain", "params" : {"commands" : [
											[0, 	"new_move_auto", {"duration" : 3000}]// move for 3 seconds
											]}},
				
										//{"type" : "LinearMotion", "params" : {"speed" : 200}},
										//{"type" : "Motion", "params" : {"dx" : 0, "dy" : 0}},
										//{"type" : "Damaging", "params" : {"damage" : 5}},
										//{"type" : "DeleteOnCollision", "params" : {}},

										{"type" : "new_movable:NewMovable", "params" :  {"velocity" : 1000, "accelerate" : -10}},
										{"type" : "new_collidable:NewCollidable", "params" : {"x" : 8, "y" : 8, "ignore_position_fix" : true, "ignore_collision_with" : 3}},
										{"type" : "renderable_model:RenderableModel", "params" : {"model" : "wooden_arrow.json"}}
									]
								} 
							}
						}
					]
				},

				{
					"id" : "wooden_bow",
					"templates" : [],
					"components" : [
						{"type" : "weapon:Weapon", "params" : {"type" : "bow",	"max_projectiles" : 5}},
						{"type" : "renderable_model:RenderableModel", "params" : {"model" : "bow.json"}}
					]
				},

				{
					"id" : "player01",
					"templates" : ["darkmale"],
					"components" : [

						{"type" : "new_debug:NewDebug", "params" : {"movement" : {"width" : 1, "color" : [0, 255, 0]}}},
						{"type" : "new_collidable:NewCollidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}},

						{"type" : "new_controllable:NewControllable", "params" :  {"key_profile" : "default",
							"control_cmds" : {
								"left" : [["new_move_add", {"moves" : ["left"]}]],
								"right": [["new_move_add", {"moves" : ["right"]}]],
								"up" : [["new_move_add", {"moves" : ["up"]}]],
								"down" : [["new_move_add", {"moves" : ["down"]}]],
								"attack" : [["new_attack", {}]]}
							}
						},

						// Bow is armed and preselected as the active weapon
