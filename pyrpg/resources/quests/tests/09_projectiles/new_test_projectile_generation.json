{
	"id" : "new_test_projectile_generation",
	"name" : "Test of Projectile Generation",
	"description" : "Test of Attack and Factory system - generation of projectile",
	"objective" : "POC of the new Attack and Factory system",
	"init_phase" : "phase01",

	"processors" : [

		// For commands
		["NewGenerateCommandFromBrainProcessor", {}], // Also projectile needs to have brain in order to move
		["NewGenerateCommandFromInputProcessor", {}],
		["NewPerformCommandProcessor", {}],

		// For movement - projectile must have NewFlagDoMove in order to move and not fail to idle
		// ideally if some command can be in place to tell him to move in his brain - new_move_auto command
		["NewPerformMovementProcessor", {}],

		// For animation
		["NewPerformMovementAnimationProcessor", {}],
		["NewPerformActionAnimationProcessor", {}],
		["NewPerformActionIdleAnimationProcessor", {}],
		["NewPerformIdleAnimationProcessor", {}],
		["NewPerformFrameUpdateProcessor", {}],

		// NEW - For projectile data generation
		["NewGenerateProjectileFactoryDataProcessor", {}],

		// NEW - For generation of projectile from factory and projectile data
		["NewPerformFactoryGenerationProcessor", {}],

		// Help to debug the value of given component into the log, if necessary
		["NewListComponentsProcessor", {"comp_name" : "Position"}],

		
		// For displaying on screen
		["NewPerformClearWindowProcessor", {}],
		["NewPerformClearCameraProcessor", {}],
		["NewPerformScrollCameraProcessor", {}],
		["NewPerformRenderMapProcessor", {}],
		["NewGenerateRenderDataFromParentProcessor", {}],
		["NewPerformRenderModelProcessor", {}],
		["NewPerformRenderArmedWeaponProcessor", {}],
		["NewPerformRenderArmedAmmoProcessor", {}],
		["NewPerformRenderDebugInfoProcessor", {}],
		["NewPerformBlitCameraProcessor", {}],


		// For processing input and movements and attacks
		["NewRemoveFlagDoMoveProcessor", {}],
		["NewRemoveFlagDoAttackProcessor", {}],
		["NewRemoveFlagIsAnimationActionFrameProcessor", {}],
		["NewRemoveFlagCreateFromFactoryProcessor", {}] // NEW - for removing flag for generation of projectile

