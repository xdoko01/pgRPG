	"phases" : {
		"phase01" :{
			"name" : "Projectile Generation Test", "objective" : "","maps" : ["test_arena_sand"],
			
			"cleanup" : {"maps" : [], "entities" : []}, "dialogs" : [],

			"entities" : [
				
				// AmmoPack is Factory for generation of arrows
				{
					"id" : "wooden_arrows_pack",
					"templates" : [],
					"components" : [
						{"type" : "AmmoPack", "params" : {"weapon" : "bow", "type" : "wooden_arrows_pack"}},
						{"type" : "RenderableModel", "params" : {"model" : "wooden_arrows_pack.json"}},
						{
							"type" : "NewFactory", 
							"params" : {
								"prescription" : {
									"id" : "wooden_arrow",
									"templates" : [],
									"components" : [
										{"type" : "NewDebug", "params" : {}},

										{"type" : "Brain", "params" : {"commands" : [
											[0, 	"new_move_auto", {"duration" : 3000}], // move for 3 seconds
											]}},
				
										//{"type" : "LinearMotion", "params" : {"speed" : 200}},
										//{"type" : "Motion", "params" : {"dx" : 0, "dy" : 0}},
										//{"type" : "Damaging", "params" : {"damage" : 5}},
										//{"type" : "DeleteOnCollision", "params" : {}},

										{"type" : "NewMovable", "params" :  {"velocity" : 100}},
										{"type" : "NewCollidable", "params" : {"x" : 8, "y" : 8}},
										{"type" : "RenderableModel", "params" : {"model" : "wooden_arrow.json"}}
									]
								} 
							}
						}
					]
				},

				{
					"id" : "wooden_bow",
					"templates" : [],
					"components" : [
						{"type" : "Weapon", "params" : {"type" : "bow",	"max_projectiles" : 5}},
						{"type" : "RenderableModel", "params" : {"model" : "bow.json"}}
					]
				},

				{
					"id" : "player01",
					"templates" : ["darkmale"],
					"components" : [

						{"type" : "NewDebug", "params" : {"movement" : {"width" : 1, "color" : [0, 255, 0]}}},
						{"type" : "NewCollidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}},

						{"type" : "NewControllable", "params" :  {"key_profile" : "default",
							"control_cmds" : {
								"left" : [["new_move_add", {"moves" : ["left"]}]],
								"right": [["new_move_add", {"moves" : ["right"]}]],
								"up" : [["new_move_add", {"moves" : ["up"]}]],
								"down" : [["new_move_add", {"moves" : ["down"]}]],
								"attack" : [["new_attack", {}]]}
							}
						},

						// Bow is armed and preselected as the active weapon
						{"type" : "NewHasWeapon", "params" : {
							"weapons" : {
								"bow" : {"weapon" : "wooden_bow", "generator" : "wooden_arrows_pack"}
							}
						}},

						{"type" : "NewWeaponInUse", "params" :  {"type" : "bow"}},

						{"type" : "Position", "params" : {"x" : 250, "y" : 250, "map" : "test_arena_sand"}},
						{"type" : "NewMovable", "params" :  {"velocity" : 200}},
						{"type" : "Camera", "params" : {"always_center": false, "screen_pos_x" : 0, "screen_pos_y" : 0, "screen_width" : 640, "screen_height" : 480}}
					]
				}
