									"components" : [
										{"type" : "new.debug:Debug", "params" : {}},

										{"type" : "new.brain:Brain", "params" : {"commands" : [
											[0, 	"new_move_auto", {}] // duration is not specified so the movement is infinite
											]}},

										{"type" : "new.damaging:Damaging", "params" : {"damage" : 50}},

										{"type" : "new.movable:Movable", "params" :  {"velocity" : 500}},
										{"type" : "new.collidable:Collidable", "params" : {"x" : 8, "y" : 8, "accept_pos_fix_from_denylist" : ["ALL"]}},
										{"type" : "new.destroy_on_collision:DestroyOnCollision", "params" : {"ttl" : 0}},
										
										{"type" : "new.visual_fx_on_collision:VisualFXOnCollision", "params" : {"effect" : "new/effects/explosion"}},
										{"type" : "new.sound_fx_on_collision:SoundFXOnCollision", "params" : {"sound" : "hurt/shade12.wav"}}


									]
								}
							}
						}
					]
				},

				{
					"id" : "spell_ability",
					"templates" : [],
					"components" : [
						{"type" : "new.weapon:Weapon", "params" : {"type" : "spell",	"max_projectiles" : 5}}
					]
				},

				{
					"id" : "player01",
					"templates" : ["new/model/body/male/human/white"],
					"components" : [

						{"type" : "new.debug:Debug", "params" : {"movement" : {"width" : 1, "color" : [0, 255, 0]}}},

						{
							"type" : "new.collidable:Collidable", 
							"params" :  {
								"x" : 15, "y" : 27, "dx" : 0, "dy" : 8//,
								//"accept_pos_fix_from_denylist" : ["ALL"] // no one can move the player - projectile cannot move the player. If missing projectile will move the player
							}
						},

						{"type" : "new.controllable:Controllable", "params" :  {"key_profile" : "default",
							"control_cmds" : {
								"left" : [["new_move_add", {"moves" : ["left"]}]],
								"right": [["new_move_add", {"moves" : ["right"]}]],
								"up" : [["new_move_add", {"moves" : ["up"]}]],
								"down" : [["new_move_add", {"moves" : ["down"]}]],
								"attack" : [["new_attack", {}]]}
							}
						},

						// Bow is armed and preselected as the active weapon
						{"type" : "new.has_weapon:HasWeapon", "params" : {
							"weapons" : {
								"bow" : {"weapon" : "wooden_bow", "generator" : "wooden_arrows_pack"},
								"sword" : {"weapon" : "long_sword", "generator" : "sword_generator"},
								"spear" : {"weapon" : "long_spear", "generator" : "spear_generator"},
								"spell" : {"weapon" : "spell_ability", "generator" : "spell_pack"}

							}
						}},

						{"type" : "new.has_score:HasScore", "params" : {}},

						//{"type" : "new.weapon_in_use:WeaponInUse", "params" :  {"type" : "bow"}},
						{"type" : "new.weapon_in_use:WeaponInUse", "params" :  {"type" : "spell"}},

						{"type" : "new.position:Position", "params" : {"x" : 250, "y" : 250, "map" : "test_arena_sand"}},
						{"type" : "new.movable:Movable", "params" :  {"velocity" : 200}},
						{"type" : "new.camera:Camera", "params" : {"always_center": false, "screen_pos_x" : 0, "screen_pos_y" : 0, "screen_width" : 640, "screen_height" : 480}}
					]
				},
				{
					"id" : "NPC01",
					"templates" : ["new/model/body/special/minotaur"],
					"components" : [
						{"type" : "new.debug:Debug", "params" : {}},

						// Move right - left
						{"type" : "new.brain:Brain", "params" : {"commands" : [
							[0, 	"new_move_to", {"x" : 1000, "y" : 450}],
							[1, 	"new_move_to", {"x" : 10, "y" : 450}],
							[0, 	"goto", {}]
						]}},


						{"type" : "new.destroy_on_no_health:DestroyOnNoHealth", "params" : {"ttl" : 10000}},
						{"type" : "new.scorable_on_damage:ScorableOnDamage", "params" : {"score" : 10}},

						{"type" : "new.damageable:Damageable", "params" : {"health" : 100}},

						{"type" : "new.position:Position", "params" : {"x" : 10, "y" : 450, "map" : "test_arena_sand"}},
						{"type" : "new.movable:Movable", "params" :  {"velocity" : 100}},
						{"type" : "new.collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}}
					]
				},
				{
					"id" : "NPC02",
					"templates" : ["new/model/body/special/minotaur"],
					"components" : [
						{"type" : "new.debug:Debug", "params" : {}},

						{"type" : "new.scorable_on_no_health:ScorableOnNoHealth", "params" : {"score" : 1000}},
						{"type" : "new.destroy_on_no_health:DestroyOnNoHealth", "params" : {"ttl" : 10000}},

						{"type" : "new.damageable:Damageable", "params" : {"health" : 100}},

						{"type" : "new.position:Position", "params" : {"x" : 100, "y" : 100, "map" : "test_arena_sand"}},
						{"type" : "new.movable:Movable", "params" :  {"velocity" : 100}},
						{"type" : "new.collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}}
					]
				}

