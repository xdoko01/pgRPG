{
	// Basic data
	"id" : "new_test_render_02",
	"title" : "Render Map Test",
	"description" : "Test new render processors",
	"objective" : "POC of the new render system - display scrollable map",

	// What quests need to be loaded before this one
	"prereqs" : [],

	// What objects need to be cleaned first
	"cleanup" : {
		"processors": [],
		"maps": [], 
		"templates": [], 
		"entities": [], 
		"dialogs": [],
		"handlers": []
	},

	// What processors to load
	"processors" : [
		// For commands
		["new.command_system.generate_command_from_input_processor:GenerateCommandFromInputProcessor", {}],
		["new.command_system.perform_command_processor:PerformCommandProcessor", {}],

		// For movement
		["new.movement_system.perform_movement_processor:PerformMovementProcessor", {}],

		// For displaying
		["new.render_system.perform_clear_window_processor:PerformClearWindowProcessor", {"clear_color" : [50, 150, 50]}], // clear the game window
		["new.render_system.perform_clear_camera_processor:PerformClearCameraProcessor", {"clear_color" : [100, 0, 0]}], // clear all camera surfaces
		["new.render_system.perform_scroll_camera_processor:PerformScrollCameraProcessor", {}], // scroll the camera
		["new.render_system.perform_render_map_processor:PerformRenderMapProcessor", {}], // display map
		["new.render_system.perform_blit_camera_processor:PerformBlitCameraProcessor", {}], // display all cameras on the game window

		// For movement
		["new.movement_system.remove_flag_do_move_processor:RemoveFlagDoMoveProcessor", {}]
	],

	// What maps to load
	"maps" : ["test_arena_sand"],

	// What dialogs to load
	"dialogs": [],

	// What templates to load
	"templates": [],

	// What entities to load
	"entities" : [

		// In order to display anything, entity with Camera and Position must exist
		// Multiple cameras are supported
		{
			"id" : "camera01",
			"templates" : [],
			"components" : [

				// Component to control camera using keyboard
				{"type" : "new.controllable:Controllable", "params" :  {"key_profile" : "default",
					"control_cmds" : {
						"left" : [["new_move_add", {"moves" : ["left"]}]],
						"right": [["new_move_add", {"moves" : ["right"]}]],
						"up" : [["new_move_add", {"moves" : ["up"]}]],
						"down" : [["new_move_add", {"moves" : ["down"]}]],
						"attack" : null}
					}
				},

				// Without Movable component the Camera won't move
				{"type" : "new.movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "new.position:Position", "params" : {"x" : 250, "y" : 250, "map" : "test_arena_sand"}},

				// When moving camera it makes sense to have it always centred
				{"type" : "new.camera:Camera", "params" : {"always_center": true, "screen_pos_x" : 5, "screen_pos_y" : 5, "screen_width" : 630, "screen_height" : 230}}
			]
		},
		{
			"id" : "camera02",
			"templates" : [],
			"components" : [
				{"type" : "new.position:Position", "params" : {"x" : 2000, "y" : 2000, "map" : "test_arena_sand"}},
				{"type" : "new.camera:Camera", "params" : {"always_center": false, "screen_pos_x" : 5, "screen_pos_y" : 245, "screen_width" : 630, "screen_height" : 230}}
			]
		}
	],

	// How to handle events
	"event_handlers": {}
}