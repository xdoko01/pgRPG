{
	"$schema": "../../../../../core/schemas/new/quest.schema.json",

	// Basic data
	"id" : "test_fx_01",
	"title" : "Test of SFX and VFX",
	"description" : "Test of Sound and Visual Effects processors",
	"objective" : "POC of the new effect system",

	// What quests need to be loaded before this one
	"prereqs" : [],

	// What objects need to be cleaned first
	"cleanup" : {
		"processors": [],
		"maps": [], 
		"templates": [], 
		"entities": [], 
		"dialogs": [],
		"handlers": []
	},

	// What processors to load
	"processors" : [

		// For commands
		["new.command_system.generate_command_from_input_processor:GenerateCommandFromInputProcessor", {}],
		["new.command_system.generate_command_from_brain_processor:GenerateCommandFromBrainProcessor", {}],
		["new.command_system.perform_command_processor:PerformCommandProcessor", {}],

		// For movement - projectile must have FlagDoMove in order to move and not fail to idle
		// ideally if some command can be in place to tell him to move in his brain - new_move_auto command
		["new.movement_system.perform_movement_processor:PerformMovementProcessor", {}],

		// For animation
		["new.animation_system.perform_movement_animation_processor:PerformMovementAnimationProcessor", {}],
		["new.animation_system.perform_action_animation_processor:PerformActionAnimationProcessor", {}],
		["new.animation_system.perform_action_idle_animation_processor:PerformActionIdleAnimationProcessor", {}],
		["new.animation_system.perform_idle_animation_processor:PerformIdleAnimationProcessor", {}],
		["new.animation_system.perform_expire_animation_processor:PerformExpireAnimationProcessor", {}],
		["new.animation_system.perform_frame_update_processor:PerformFrameUpdateProcessor", {}],

		// NEW - For projectile data generation
		["new.attack_system.generate_projectile_factory_data_processor:GenerateProjectileFactoryDataProcessor", {}],

		// NEW - For generation of projectile from factory and projectile data
		["new.factory_system.perform_factory_generation_processor:PerformFactoryGenerationProcessor", {}],

		// NEW - adjust collision component of the entity - mainly for factory generated entities
		["new.collision_system.perform_adjust_collidable_processor:PerformAdjustCollidableProcessor", {}],

		// NEW - adjust movable component of the entity - mainly for factory generated entities
		["new.movement_system.perform_adjust_movement_processor:PerformAdjustMovementProcessor", {}],

		// NEW - adjust damaging component of the entity - mainly for factory generated entities
		["new.damage_system.perform_adjust_damaging_processor:PerformAdjustDamagingProcessor", {}],

		// For collisions
		["new.collision_system:GenerateCollisionsProcessor", {}],
		["new.collision_system:ResolveCollisionsProcessor", {}],
		
		// NEW - For damages
		["new.damage_system:GenerateDamageProcessor", {}],
		["new.damage_system:PerformDamageProcessor", {}],

		// NEW - For score
		["new.score_system:GenerateScoreOnDamageProcessor", {}],
		["new.score_system:GenerateScoreOnNoHealthProcessor", {}],
		["new.score_system:CalculateScoreProcessor", {}],
		
		// For destroy
		["new.destroy_system.generate_destroy_on_collision_processor:GenerateDestroyOnCollisionProcessor", {}],
		["new.destroy_system.generate_destroy_on_stopped_movement_processor:GenerateDestroyOnStoppedMovementProcessor", {}],
		["new.destroy_system.generate_destroy_on_no_health_processor:GenerateDestroyOnNoHealthProcessor", {}],
		["new.destroy_system.perform_destroy_entities_processor:PerformDestroyEntitiesProcessor", {}],

		// For visual and sound effects
		["new.effects_system.generate_visual_fx_on_collision_processor:GenerateVisualFXOnCollisionProcessor", {}],
		["new.effects_system.generate_visual_fx_on_creation_processor:GenerateVisualFXOnCreationProcessor", {}],
		["new.effects_system.generate_visual_fx_on_damage_processor:GenerateVisualFXOnDamageProcessor", {}],
		["new.effects_system.generate_visual_fx_on_generation_processor:GenerateVisualFXOnGenerationProcessor", {}],
		["new.effects_system.generate_visual_fx_on_no_health_processor:GenerateVisualFXOnNoHealthProcessor", {}],

		["new.effects_system.generate_sound_fx_on_collision_processor:GenerateSoundFXOnCollisionProcessor", {}],
		["new.effects_system.generate_sound_fx_on_damage_processor:GenerateSoundFXOnDamageProcessor", {}],
		["new.effects_system.generate_sound_fx_on_no_health_processor:GenerateSoundFXOnNoHealthProcessor", {}],
		["new.effects_system.generate_sound_fx_on_creation_processor:GenerateSoundFXOnCreationProcessor", {}],
		["new.effects_system.generate_sound_fx_on_generation_processor:GenerateSoundFXOnGenerationProcessor", {}],

		// For displaying on screen
		["new.render_system.perform_clear_window_processor:PerformClearWindowProcessor", {}],
		["new.render_system.perform_clear_camera_processor:PerformClearCameraProcessor", {}],
		["new.render_system.perform_scroll_camera_processor:PerformScrollCameraProcessor", {}],
		["new.render_system.perform_render_map_processor:PerformRenderMapProcessor", {}],
		["new.render_system.generate_render_data_from_parent_processor:GenerateRenderDataFromParentProcessor", {}],
		["new.render_system.perform_render_model_processor:PerformRenderModelProcessor", {}],
		["new.render_system.perform_render_armed_weapon_processor:PerformRenderArmedWeaponProcessor", {}],
		["new.render_system.perform_render_armed_ammo_processor:PerformRenderArmedAmmoProcessor", {}],
		["new.render_system.perform_render_debug_info_processor:PerformRenderDebugInfoProcessor", {}],
		["new.render_system.perform_blit_camera_processor:PerformBlitCameraProcessor", {}],

		// For events processing - display the dialog on the start of the quest - after first game screen is generated
		["original.game_events_processor:GameEventsExProcessor", {"process" : ["QUEST_START"]}],

		// Removal of obsolete flags
		["new.movement_system.remove_flag_do_move_processor:RemoveFlagDoMoveProcessor", {}],
		["new.movement_system.remove_flag_adjust_movement_processor:RemoveFlagAdjustMovementProcessor", {}],
		["new.movement_system.remove_flag_has_stopped_movement_processor:RemoveFlagHasStoppedMovementProcessor", {}],

		["new.collision_system.remove_flag_has_collided_processor:RemoveFlagHasCollidedProcessor", {}],
		["new.collision_system.remove_flag_adjust_collidable_processor:RemoveFlagAdjustCollidableProcessor", {}],
		["new.attack_system.remove_flag_do_attack_processor:RemoveFlagDoAttackProcessor", {}],
		["new.animation_system.remove_flag_is_animation_action_frame_processor:RemoveFlagIsAnimationActionFrameProcessor", {}],
		["new.factory_system.remove_flag_create_from_factory_processor:RemoveFlagCreateFromFactoryProcessor", {}],
		["new.factory_system.remove_flag_generated_from_factory_processor:RemoveFlagGeneratedFromFactoryProcessor", {}],


		["new.damage_system.remove_flag_is_about_to_be_damaged_by_processor:RemoveFlagIsAboutToBeDamagedByProcessor", {}],
		["new.damage_system.remove_flag_was_damaged_by_processor:RemoveFlagWasDamagedByProcessor", {}],
		["new.damage_system.remove_flag_has_damaged_processor:RemoveFlagHasDamagedProcessor", {}],
		["new.damage_system.remove_flag_adjust_damaging_processor:RemoveFlagAdjustDamagingProcessor", {}],
		["new.damage_system.remove_flag_has_no_health_processor:RemoveFlagHasNoHealthProcessor", {}],

		["new.score_system.remove_flag_has_scored_processor:RemoveFlagHasScoredProcessor", {}]

		// For logging performance of processors - timed must be True for this processor to work
		//["new.debug_system.debug_processor_performance_processor:DebugProcessorPerformanceProcessor", {}]
	],

	// What maps to load
	"maps" : ["test_arena_sand"],

	// What dialogs to load
	"dialogs": [],

	// What templates to load
	"templates": [],

	// What entities to load
	"entities" : [
		
		// Spear
		{
			"id" : "spear_generator",
			"templates" : [], // no model needed
			"components" : [
				{"type" : "new.ammo_pack:AmmoPack", "params" : {"weapon" : "spear", "type" : "regular_spear_thrust"}},
				{"type" : "new.sound_fx_on_generation:SoundFXOnGeneration", "params" : {"sound" : "hurt/shade12.wav"}},
				{"type" : "new.visual_fx_on_generation:VisualFXOnGeneration", "params" : {"effect" : "new/effects/explosion", "fixed_position" : true}},

				{
					"type" : "new.factory:Factory", 
					"params" : {
						"prescription" : {
							"id": "spear_generator_collision_zone",
							"templates" : [], // Only collision zone is created, no sprite.
							"components" : [
								{"type" : "new.debug:Debug", "params" : {}},

								{
									"type" : "new.collidable:Collidable", 
									"params" : {
										"x" : 8, "y" : 8, 
										"accept_pos_fix_from_denylist" : ["ALL"], // never change position of the sword slash upon collision with anybody
										"apply_pos_fix_to_denylist" : ["ALL"] // never change position of the entity that was slashed
										}},
								
								{"type" : "new.damaging:Damaging", "params" : {"damage" : 10}},

								//{"type" : "new.destroy_on_collision:DestroyOnCollision", "params" : {"ttl" : 0}},
								{"type" : "new.is_destroyed:IsDestroyed", "params" : {"ttl" : 0}},

								{"type" : "new.visual_fx_on_collision:VisualFXOnCollision", "params" : {"effect" : "new/effects/explosion"}},
								{"type" : "new.visual_fx_on_creation:VisualFXOnCreation", "params" : {"effect" : "new/effects/explosion"}}


							]
						}
					}
				}
			]
		},

		{
			"id" : "long_spear",
			"templates" : ["new/model/weapon/thrust/spear"],
			"components" : [
				{"type" : "new.weapon:Weapon", "params" : {"type" : "sword",	"max_projectiles" : 5}}
			]
		},


		// Dagger
		{
			"id" : "sword_generator",
			"templates" : [],
			"components" : [
				{"type" : "new.ammo_pack:AmmoPack", "params" : {"weapon" : "sword", "type" : "regular_sword_slash"}},
				//{"type" : "new.sound_fx_on_generation:SoundFXOnGeneration", "params" : {"sound" : "hurt/shade12.wav"}},
				//{"type" : "new.visual_fx_on_generation:VisualFXOnGeneration", "params" : {"effect" : "new/effects/explosion", "fixed_position" : true}},

				{
					"type" : "new.factory:Factory",
					"params" : {
						"prescription" : {
							
							"templates" : [], // Only collision zone is created, no sprite.
							"components" : [
								{"type" : "new.debug:Debug", "params" : {}},

								{
									"type" : "new.collidable:Collidable", 
									"params" : {
										"x" : 8, "y" : 8, 
										"accept_pos_fix_from_denylist" : ["ALL"], // never change position of the sword slash upon collision with anybody
										"apply_pos_fix_to_denylist" : ["ALL"] // never change position of the entity that was slashed
										}},
								
								{"type" : "new.damaging:Damaging", "params" : {"damage" : 20}},

								//{"type" : "new.destroy_on_collision:DestroyOnCollision", "params" : {"ttl" : 0}},
								{"type" : "new.is_destroyed:IsDestroyed", "params" : {"ttl" : 0}},

								{"type" : "new.visual_fx_on_collision:VisualFXOnCollision", "params" : {"effect" : "new/effects/explosion"}}
								//{"type" : "new.visual_fx_on_creation:VisualFXOnCreation", "params" : {"effect" : "new/effects/explosion"}}

							]
						}
					}
				}
			]
		},

		{
			"id" : "long_sword",
			"templates" : ["new/model/weapon/slash/dagger"],
			"components" : [
				{"type" : "new.weapon:Weapon", "params" : {"type" : "spear",	"max_projectiles" : 5}}
			]
		},


		// wooden_arrows_pack AmmoPack is Factory for generation of arrows
		// Definition can be found in entity json files
		{
			"id" : "wooden_arrows_pack",
			"templates" : ["new/thing/ammo_pack/shoot/wooden_arrows_pack"],
			"components" : [
				{"type" : "new.visual_fx_on_generation:VisualFXOnGeneration", "params" : {"effect" : "new/effects/explosion", "fixed_position" : true}}
			]
		},

		{
			"id" : "wooden_bow",
			"templates" : ["new/model/weapon/shoot/bow_wooden_big"],
			"components" : [
				{"type" : "new.weapon:Weapon", "params" : {"type" : "bow",	"max_projectiles" : 5}}
			]
		},

		{
			"id" : "spell_pack",
			"templates" : [],
			"components" : [
				{"type" : "new.ammo_pack:AmmoPack", "params" : {"weapon" : "spell", "type" : "fireball"}},
				{"type" : "new.sound_fx_on_generation:SoundFXOnGeneration", "params" : {"sound" : "hurt/shade12.wav"}},
				{"type" : "new.visual_fx_on_generation:VisualFXOnGeneration", "params" : {"effect" : "new/effects/explosion", "fixed_position": true}},

				{
					"type" : "new.factory:Factory", 
					"params" : {
						"prescription" : {
							"id": "spell_pack_arrow",
							"templates" : ["new/model/ammo/shoot/wooden_arrow"],
							"components" : [
								{"type" : "new.debug:Debug", "params" : {}},

								{
									"type" : "new.brain_ai:BrainAI",
									"params" : {
										"cmd_list" : [
											{"command": ["move_auto", {"duration_ms": 3000}]}
										]
									}
								},

								{"type" : "new.damaging:Damaging", "params" : {"damage" : 50}},

								{"type" : "new.movable:Movable", "params" :  {"velocity" : 500}},
								{"type" : "new.collidable:Collidable", "params" : {"x" : 8, "y" : 8, "accept_pos_fix_from_denylist" : ["ALL"]}},
								{"type" : "new.destroy_on_collision:DestroyOnCollision", "params" : {"ttl" : 0}},
								
								{"type" : "new.visual_fx_on_collision:VisualFXOnCollision", "params" : {"effect" : "new/effects/explosion"}}
								//{"type" : "new.visual_fx_on_creation:VisualFXOnCreation", "params" : {"effect" : "new/effects/explosion"}}

							]
						}
					}
				}
			]
		},

		{
			"id" : "spell_ability",
			"templates" : [],
			"components" : [
				{"type" : "new.weapon:Weapon", "params" : {"type" : "spell",	"max_projectiles" : 5}}
			]
		},

		{
			"id" : "player01",
			"templates" : [
				"new/model/body/male/human/white",
				"new/controls/default"
			],
			"components" : [

				{"type" : "new.debug:Debug", "params" : {"movement" : {"width" : 1, "color" : [0, 255, 0]}}},

				{
					"type" : "new.collidable:Collidable", 
					"params" :  {
						"x" : 15, "y" : 27, "dx" : 0, "dy" : 8//,
						//"accept_pos_fix_from_denylist" : ["ALL"] // no one can move the player - projectile cannot move the player. If missing projectile will move the player
					}
				},


				// Bow is armed and preselected as the active weapon
				{"type" : "new.has_weapon:HasWeapon", "params" : {
					"weapons" : {
						"bow" : {"weapon" : "wooden_bow", "generator" : "wooden_arrows_pack"},
						"sword" : {"weapon" : "long_sword", "generator" : "sword_generator"},
						"spear" : {"weapon" : "long_spear", "generator" : "spear_generator"},
						"spell" : {"weapon" : "spell_ability", "generator" : "spell_pack"}

					}
				}},

				{"type" : "new.has_score:HasScore", "params" : {}},

				//{"type" : "new.weapon_in_use:WeaponInUse", "params" :  {"type" : "bow"}},
				{"type" : "new.weapon_in_use:WeaponInUse", "params" :  {"type" : "sword"}},

				{"type" : "new.position:Position", "params" : {"x" : 250, "y" : 250, "map" : "test_arena_sand"}},
				{"type" : "new.movable:Movable", "params" :  {"velocity" : 200}},
				{"type" : "new.camera:Camera", "params" : {"always_center": false, "screen_pos_x" : 0, "screen_pos_y" : 0, "screen_width" : 640, "screen_height" : 480}}
			]
		},
		{
			"id" : "NPC01",
			"templates" : ["new/model/body/special/minotaur"],
			"components" : [
				{"type" : "new.debug:Debug", "params" : {}},
				
				{
					"type": "new.brain_ai:BrainAI", 
					"params": {
						"cmd_list" : [
							{"command": ["move_to_pos_px", {"pos": [1000,450]}]},
							{"command": ["move_to_pos_px", {"pos": [10,450]}]},
							{"type": "Goto", "jmp_to": 0}
						]
					}
				},


				{"type" : "new.destroy_on_no_health:DestroyOnNoHealth", "params" : {"ttl" : 10000}},
				{"type" : "new.scorable_on_damage:ScorableOnDamage", "params" : {"score" : 10}},

				{"type" : "new.damageable:Damageable", "params" : {"health" : 100}},

				{"type" : "new.position:Position", "params" : {"x" : 10, "y" : 450, "map" : "test_arena_sand"}},
				{"type" : "new.movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "new.collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}},
				{"type" : "new.sound_fx_on_damage:SoundFXOnDamage", "params" : {"sound" : "hurt/10.mp3"}},
				{"type" : "new.sound_fx_on_no_health:SoundFXOnNoHealth", "params" : {"sound" : "hurt/9.mp3"}},
				{"type" : "new.visual_fx_on_no_health:VisualFXOnNoHealth", "params" : {"effect" : "new/effects/explosion"}}

			]
		},
		{
			"id" : "NPC02",
			"templates" : ["new/model/body/special/minotaur"],
			"components" : [
				{"type" : "new.debug:Debug", "params" : {}},

				{"type" : "new.scorable_on_no_health:ScorableOnNoHealth", "params" : {"score" : 1000}},
				{"type" : "new.destroy_on_no_health:DestroyOnNoHealth", "params" : {"ttl" : 10000}},

				{"type" : "new.damageable:Damageable", "params" : {"health" : 100}},

				{"type" : "new.position:Position", "params" : {"x" : 100, "y" : 100, "map" : "test_arena_sand"}},
				{"type" : "new.movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "new.collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}},

				{"type" : "new.sound_fx_on_damage:SoundFXOnDamage", "params" : {"sound" : "hurt/10.mp3"}},
				{"type" : "new.sound_fx_on_no_health:SoundFXOnNoHealth", "params" : {"sound" : "hurt/9.mp3"}},

				{"type" : "new.visual_fx_on_no_health:VisualFXOnNoHealth", "params" : {"effect" : "new/effects/explosion"}}

			]
		}

	],

	// How to handle events
	"handlers": [
		[
			"QUEST_START",
			{
				"id": "ev_quest_start",
				"actions": 	[
					"SCRIPT",
					"new.show_msg_window", 
					{
						"title": "%filepath",
						"html_text": "<b>Quest ID:</b> %id<br/><b>Title:</b> %title<br/><b>Description:</b> %description<br/><b>Objective:</b> %objective<br/><br/><b>Stats:</b> %stats"
					}
				]
			}
		]
	]
}