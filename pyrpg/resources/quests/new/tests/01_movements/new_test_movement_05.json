	"phases" : {
		"phase01" :{
			"name" : "Movement Test 05", "objective" : "","maps" : ["test_arena_sand"],
			
			"cleanup" : {"maps" : [],"entities" : []}, "dialogs" : [],

			"entities" : [
				{
					"id" : "player01",
					"templates" : ["new/model/body/male/human/brown"],
					"components" : [

						/////////////////////////////////////////////////////////
						// TEST 5 - Movement command based on movement directions
						// - diagonal is allowed, multiple key events supported
						// - multiple command / single direction upon keypress
						/////////////////////////////////////////////////////////
						{"type" : "new.controllable:Controllable", "params" :  {"key_profile" : "default",
							"control_cmds" : {
								"left" : [["new_move_add", {"moves" : ["left"]}], ["new_move_add", {"moves" : ["up"]}]],
								"right": [["new_move_add", {"moves" : ["right"]}], ["new_move_add", {"moves" : ["down"]}]],
								"up" : [["new_move_add", {"moves" : ["up"]}], ["new_move_add", {"moves" : ["right"]}]],
								"down" : [["new_move_add", {"moves" : ["down"]}], ["new_move_add", {"moves" : ["left"]}]],
								"attack" : [["none", {}]]}
							}
						},

						{"type" : "new.position:Position", "params" : {"x" : 250, "y" : 250, "map" : "test_arena_sand"}},
						{"type" : "new.movable:Movable", "params" :  {"velocity" : 100}},
						{"type" : "new.camera:Camera", "params" : {"always_center": false, "screen_pos_x" : 0, "screen_pos_y" : 0, "screen_width" : 640, "screen_height" : 480}}
					]
				}
			],

			"event_handling" : {

