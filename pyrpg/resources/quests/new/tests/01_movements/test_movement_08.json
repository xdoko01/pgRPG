{
	"id" : "new_test08_movement",
	"name" : "Movement Test 08",
	"description" : "Test Controllable, NewMoveable components and NewMove command",
	"objective" : "POC of the improved movement system",
	"init_phase" : "phase01",

	"processors" : [
		// For commands
		["new.command_system.generate_command_from_input_processor:GenerateCommandFromInputProcessor", {}],
		["new.command_system.generate_command_from_brain_processor:GenerateCommandFromBrainProcessor", {}],

		["new.command_system.perform_command_processor:PerformCommandProcessor", {}],

		// For movement
		["new.movement_system.perform_movement_processor:PerformMovementProcessor", {}],
		
		["new.render_system.perform_clear_window_processor:PerformClearWindowProcessor", {}],
		["new.render_system.perform_clear_camera_processor:PerformClearCameraProcessor", {}],
		["new.render_system.perform_scroll_camera_processor:PerformScrollCameraProcessor", {}],
		["new.render_system.perform_render_map_processor:PerformRenderMapProcessor", {}],
		["new.render_system.perform_render_model_processor:PerformRenderModelProcessor", {}],
		["new.render_system.perform_render_debug_info_processor:PerformRenderDebugInfoProcessor", {}],
		["new.render_system.perform_blit_camera_processor:PerformBlitCameraProcessor", {}],

		// For processing input and movements
		["new.movement_system.remove_flag_do_move_processor:RemoveFlagDoMoveProcessor", {}]
	],

	"phases" : {
		"phase01" :{
			"name" : "Movement Test 08", "objective" : "","maps" : ["test_arena_sand"],
			
			"cleanup" : {"maps" : [], "entities" : []}, "dialogs" : [],

			"entities" : [
				{
					"id" : "player01",
					"templates" : ["new/model/body/male/human/brown"],
					"components" : [

						/////////////////////////////////////////////////////////
						// TEST 8 - Movement command based on modify_brain command
						// - program is added to the brain and executed accross several cycles
						//
						/////////////////////////////////////////////////////////
						{"type" : "new.brain:Brain", "params" : {"commands" : []}},

						{"type" : "new.controllable:Controllable", "params" :  {"key_profile" : "default",
							"control_cmds" : {
								// Do 3 circles upon pressing left
								"left" : [["new_modify_brain", {"commands" : [
									[null, "new_move_vect_noadd", {"vector" : [-5, 0]}], // left
									[null, "new_move_vect_noadd", {"vector" : [0, 5]}], // down
									[null, "new_move_vect_noadd", {"vector" : [5, 0]}], // right
									[null, "new_move_vect_noadd", {"vector" : [0, -5]}], // up
									[0, "loop", {"iterations" : 3}]]}]],
								
								"right" : [["new_modify_brain", {"commands" : [
									[null, "new_move_vect_noadd", {"vector" : [10, 0]}]]}]],
								
								"up" : [["new_modify_brain", {"commands" : [
									[null, "new_move_vect_noadd", {"vector" : [0, -10]}]]}]],
								
								"down" : [["new_modify_brain", {"commands" : [
									[null, "new_move_vect_noadd", {"vector" : [0, 10]}]]}]],
	
								"attack" : [["none", {}]]}
							}
						},


						{"type" : "new.position:Position", "params" : {"x" : 250, "y" : 250, "map" : "test_arena_sand"}},
						{"type" : "new.movable:Movable", "params" :  {"velocity" : 100}},
						{"type" : "new.camera:Camera", "params" : {"always_center": false, "screen_pos_x" : 0, "screen_pos_y" : 0, "screen_width" : 640, "screen_height" : 480}}
					]
				}
			],

			"event_handling" : {

				"QUEST_START" : [
				],

				"PHASE_START" : [
				],

				"KILL" : [
				],

				"DAMAGE" : [
				],

				"COLLISION" : [
				],
	
				"TELEPORTATION" : [
				],

				"ITEM_PICKUP" : [
				],

				"WEARABLE_WEARED" : [
				],

				"WEAPON_ARMED" : [
				]

			},

			"after_steps" : [
				{
					"erase" : ""
				}
			]
		}
	}
}