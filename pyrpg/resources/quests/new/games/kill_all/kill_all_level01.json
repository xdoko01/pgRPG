								{"type" : "new.destroy_on_collision:DestroyOnCollision", "params" : {"ttl" : 0}},
								{"type" : "new.destroy_on_no_movement:DestroyOnNoMovement", "params" : {"ttl" : 0}},
								
								{"type" : "new.visual_fx_on_collision:VisualFXOnCollision", "params" : {"effect" : "new/effects/explosion"}},
								{"type" : "new.sound_fx_on_collision:SoundFXOnCollision", "params" : {"sound" : "hurt/1.mp3"}}


							]
						}
					}
				}
			]
		},

		{
			"id" : "wooden_bow",
			"templates" : ["new/model/weapon/shoot/bow_wooden_big"],
			"components" : [
				{"type" : "new.weapon:Weapon", "params" : {"type" : "bow",	"max_projectiles" : 5}}
			]
		},

		{
			"id" : "spell_pack",
			"templates" : [],
			"components" : [
				{"type" : "new.ammo_pack:AmmoPack", "params" : {"weapon" : "spell", "type" : "fireball"}},
				{
					"type" : "new.factory:Factory", 
					"params" : {
						"prescription" : {
							"templates" : ["new/model/ammo/shoot/wooden_arrow"],
							"components" : [
								{"type" : "new.debug:Debug", "params" : {}},

								{"type" : "new.brain:Brain", "params" : {"commands" : [
									[0, 	"new_move_auto", {}] // duration is not specified so the movement is infinite
									]}},

								{"type" : "new.damaging:Damaging", "params" : {"damage" : 50}},

								{"type" : "new.movable:Movable", "params" :  {"velocity" : 500}},
								{"type" : "new.collidable:Collidable", "params" : {"x" : 8, "y" : 8, "accept_pos_fix_from_denylist" : ["ALL"]}},
								{"type" : "new.destroy_on_collision:DestroyOnCollision", "params" : {"ttl" : 0}},
								
								{"type" : "new.visual_fx_on_collision:VisualFXOnCollision", "params" : {"effect" : "new/effects/explosion"}},
								{"type" : "new.sound_fx_on_collision:SoundFXOnCollision", "params" : {"sound" : "hurt/1.mp3"}}


							]
						}
					}
				}
			]
		},

		{
			"id" : "spell_ability",
			"templates" : [],
			"components" : [
				{"type" : "new.weapon:Weapon", "params" : {"type" : "spell",	"max_projectiles" : 5}}
			]
		},

		{
			"id" : "player01",
			"templates" : ["new/model/body/male/human/white", "t_tile_pos(10, 10, test_arena_sand)"],
			"components" : [

				{"type" : "new.debug:Debug", "params" : {"movement" : {"width" : 1, "color" : [0, 255, 0]}}},

				{
					"type" : "new.collidable:Collidable", 
					"params" :  {
						"x" : 15, "y" : 27, "dx" : 0, "dy" : 8//,
						//"accept_pos_fix_from_denylist" : ["ALL"] // no one can move the player - projectile cannot move the player. If missing projectile will move the player
					}
				},

				{"type" : "new.controllable:Controllable", "params" :  {"key_profile" : "default",
					"control_cmds" : {
						"left" : [["new_move_add", {"moves" : ["left"]}]],
						"right": [["new_move_add", {"moves" : ["right"]}]],
						"up" : [["new_move_add", {"moves" : ["up"]}]],
						"down" : [["new_move_add", {"moves" : ["down"]}]],
						"attack" : [["new_attack", {}]]}
					}
				},

				// Bow is armed and preselected as the active weapon
				{"type" : "new.has_weapon:HasWeapon", "params" : {
					"weapons" : {
						"bow" : {"weapon" : "wooden_bow", "generator" : "wooden_arrows_pack"},
						"sword" : {"weapon" : "long_sword", "generator" : "sword_generator"},
						"spear" : {"weapon" : "long_spear", "generator" : "spear_generator"},
						"spell" : {"weapon" : "spell_ability", "generator" : "spell_pack"}

					}
				}},

				//{"type" : "new.weapon_in_use:WeaponInUse", "params" :  {"type" : "bow"}},
				{"type" : "new.weapon_in_use:WeaponInUse", "params" :  {"type" : "spell"}},

				{"type" : "new.damageable:Damageable", "params" : {"health" : 100}},
				{"type" : "new.destroy_on_no_health:DestroyOnNoHealth", "params" : {"ttl" : 5000}},

				//{"type" : "new.position:Position", "params" : {"x" : 250, "y" : 250, "map" : "test_arena_sand"}},
				{"type" : "new.movable:Movable", "params" :  {"velocity" : 200}},
				{"type" : "new.camera:Camera", "params" : {"always_center": false, "screen_pos_x" : 0, "screen_pos_y" : 0, "screen_width" : 640, "screen_height" : 480}}
			]
		},
		// Dagger for NPC01
		{
			"id" : "sword_generator_npc01",
			"templates" : ["new/model/ammo_pack/shoot/wooden_arrows_pack"],
			"components" : [
				{"type" : "new.ammo_pack:AmmoPack", "params" : {"weapon" : "sword", "type" : "regular_sword_slash"}},
				{
					"type" : "new.factory:Factory", 
					"params" : {
						"prescription" : {
							"templates" : [], // Only collision zone is created, no sprite.
							"components" : [
								{"type" : "new.debug:Debug", "params" : {}},

								{
									"type" : "new.collidable:Collidable", 
									"params" : {
										"x" : 16, "y" : 16, 
										"accept_pos_fix_from_denylist" : ["ALL"], // never change position of the sword slash upon collision with anybody
										"apply_pos_fix_to_denylist" : ["ALL"] // never change position of the entity that was slashed
										}},
								
								{"type" : "new.damaging:Damaging", "params" : {"damage" : 20}},

								//{"type" : "new.destroy_on_collision:DestroyOnCollision", "params" : {"ttl" : 0}},
								{"type" : "new.is_destroyed:IsDestroyed", "params" : {"ttl" : 0}},

								{"type" : "new.visual_fx_on_collision:VisualFXOnCollision", "params" : {"effect" : "new/effects/explosion"}}//,
								//{"type" : "new.sound_fx_on_collision:SoundFXOnCollision", "params" : {"sound" : "hurt/1.mp3"}}


							]
						}
					}
				}
			]
		},
		{
			"id" : "long_sword_npc01",
			"templates" : ["new/model/weapon/slash/dagger"],
			"components" : [
				{"type" : "new.weapon:Weapon", "params" : {"type" : "sword",	"max_projectiles" : 5}}
			]
		},

		{
			"id" : "NPC01",
			"templates" : ["new/model/body/special/minotaur",  "t_tile_pos(3, 20, test_arena_sand)"],
			"components" : [
				{"type" : "new.debug:Debug", "params" : {}},

				// Guard, Seek and destroy the player
				{"type" : "new.brain:Brain", "params" : {"commands" : [
					[0, 	"new_guard", {"enemy": "player01", "radius": 200, "update_time_ms": 2000}], // when player01 approaches, continue and destroy him
					[1, 	"new_move_to_target", {"target" : "player01", "radius": 50, "update_time_ms": 500}], // the lower update time the more difficult to run away
					[2, 	"new_attack_full", {"attack_time_ms": 500}],
					[1, 	"goto", {}]
				]}},

				// Sword
				{"type" : "new.has_weapon:HasWeapon", "params" : {
					"weapons" : {
						"sword" : {"weapon" : "long_sword_npc01", "generator" : "sword_generator_npc01"}
					}
				}},

				{"type" : "new.weapon_in_use:WeaponInUse", "params" :  {"type" : "sword"}},

				{"type" : "new.damaging:Damaging", "params" : {"damage" : 5}},
				{"type" : "new.damageable:Damageable", "params" : {"health" : 100}},
				{"type" : "new.destroy_on_no_health:DestroyOnNoHealth", "params" : {"ttl" : 10000}},


				{"type" : "new.movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "new.collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}}
			]
		},
		{
			"id" : "wooden_arrows_pack_npc02",
			"templates" : ["new/model/ammo_pack/shoot/wooden_arrows_pack"],
			"components" : [
				{"type" : "new.ammo_pack:AmmoPack", "params" : {"weapon" : "bow", "type" : "wooden_arrows_pack"}},
				{
					"type" : "new.factory:Factory", 
					"params" : {
						"prescription" : {
							"templates" : ["new/model/ammo/shoot/wooden_arrow"],
							"components" : [
								{"type" : "new.debug:Debug", "params" : {}},

								{"type" : "new.brain:Brain", "params" : {"commands" : [
									[0, 	"new_move_auto", {}] // duration is not specified so the movement is infinite
									]}},

								{"type" : "new.damaging:Damaging", "params" : {"damage" : 25}},

								{"type" : "new.movable:Movable", "params" :  {"velocity" : 500, "accelerate" : -3}},
								{"type" : "new.collidable:Collidable", "params" : {"x" : 8, "y" : 8, "accept_pos_fix_from_denylist" : ["ALL"]}},
								{"type" : "new.destroy_on_collision:DestroyOnCollision", "params" : {"ttl" : 0}},
								{"type" : "new.destroy_on_no_movement:DestroyOnNoMovement", "params" : {"ttl" : 0}},
								
								{"type" : "new.visual_fx_on_collision:VisualFXOnCollision", "params" : {"effect" : "new/effects/explosion"}},
								{"type" : "new.sound_fx_on_collision:SoundFXOnCollision", "params" : {"sound" : "hurt/1.mp3"}}


							]
						}
					}
				}
			]
		},

		{
			"id" : "wooden_bow_npc02",
			"templates" : ["new/model/weapon/shoot/bow_wooden_big"],
			"components" : [
				{"type" : "new.weapon:Weapon", "params" : {"type" : "bow",	"max_projectiles" : 5}}
			]
		},
		{
			"id" : "NPC02",
			"templates" : [
				"new/model/body/male/human/white()",	// template for the model
				//"t_tile_pos(5, 5, test_arena_sand)",	// template for the position - valid form
				//["t_tile_pos", [5, 5, "test_arena_sand"]], // other syntax for template - valid form
				//["t_tile_pos", {"$tileX": 5, "$tileY": 5, "$map": "test_arena_sand"}],
				//["t_tile_pos", [5, 5], {"$map": "test_arena_sand"}],
				//"t_tile_pos($tileX=5, $tileY=5, test_arena_sand)",	// template for the position - valid form
				//"t_tile_pos(5, 5, $map=test_arena_sand)",	// template for the position - valid form
				"t_tile_pos($map=test_arena_sand, $tileY=5, $tileX=5)",	// template for the position - valid form

				"new/_special/hunter(player01, 150, 1200, 100)"	// template for the btree behavior
			],
			
			"components" : [
				{"type" : "new.debug:Debug", "params" : {}},

				// Seek and destroy the player
				// 1/ move around
				// 2/ check if you see anyone with controllable or targets before you (parameters can be visibility)
				// 3/ when you see - save the target that you are following and its components
				// 4/ start following the target
				// 5/ when in range, attack
				// 6/ check if the target is alive - if no, move to original position and start over
				// 7/ check if my health is low - if yes, run away from the target
				

				{
					"type" : "new.btree:BTree", 
					"params" : {
						"blackboard": {
						},
						"tree": {
							// Find and attack target
							"type": "Sequence",
							"name": "Hunter",
							"children": [
								{
									// Find target
									"type": "Sequence",
									"name": "Find Target",
									"children": [
										{
											// Find target and save it on the bb
											"type": "Behavior",
											"name": "Set Target",
											"cmd_process": ["bb_set_globals", {"bb_target_entity": "player01"}]
										}
									]
								},
								{
									"type": "TemplateTree",
									"name": "Destroy Target",
									///
									// Different options how to fill template with the data - all valid
									///

									//"template": ["destroy_target", {"$target": "player01", "$range": 150, "$get_target_pos_ms": 1200, "$hunt_time": 5}]
									//"template": "destroy_target(player01, 150, 1200, 5)"
									//"template": "destroy_target($target=player01, $range=150, $get_target_pos_ms=1200, $hunt_time=5)"
									//"template": "destroy_target(player01, 150, 1200, $hunt_time=5)"
									//"template": ["destroy_target", ["player01", 150, 1200, 5]]
									//"template": ["destroy_target", ["player01", 150,1200], {"$hunt_time": 5}]
									//"template": ["destroy_target", ["player01", 150], {"$hunt_time": 5}]
									"template": "destroy_target(player01)"


								}
							]
						}
					}
				},
				{"type" : "new.has_weapon:HasWeapon", "params" : {
					"weapons" : {
						"bow" : {"weapon" : "wooden_bow_npc02", "generator" : "wooden_arrows_pack_npc02"}
					}
				}},

				{"type" : "new.weapon_in_use:WeaponInUse", "params" :  {"type" : "bow"}},

				{"type" : "new.damageable:Damageable", "params" : {"health" : 100}},
				{"type" : "new.destroy_on_no_health:DestroyOnNoHealth", "params" : {"ttl" : 10000}},


				{"type" : "new.movable:Movable", "params" :  {"velocity" : 50}},
				{"type" : "new.collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}}
			]
		}

	],

	// How to handle events
	"event_handlers" : {
		"DESTROYED": [
			{
				"id": "h_all_npcs_destroyed",
				"actions": [
					"IF",
					["AND",
						["==", ["SCRIPT", "new.games.kill_all.entity_exists", {"alias": "NPC01"}], false],
						["==", ["SCRIPT", "new.games.kill_all.entity_exists", {"alias": "NPC02"}], false]
					],
					["SEQ",

						["SCRIPT", "new.show_msg_window", {"html_text" : " NPC01 and NPC02 destroyed"}],
						[
							"SCRIPT", 
							"new.show_confirm_dlg", 
							{
								"title": "Play again?",
								"long_desc" : "Do you want to play again?",
								"event_type": "CUST_UI_CONFIRM",
								"event_params" : {
									"from": "h_player01_destroyed"
								}
							}
						]
					]
				]
			},
			{
				"id": "h_player01_destroyed",
				"actions": [
					"IF",
					["==", ["SCRIPT", "new.games.kill_all.entity_exists", {"alias": "player01"}], false],
					["SEQ",
							["SCRIPT", "new.show_msg_window", {"html_text" : "You died"}],
							[
								"SCRIPT", 
								"new.show_confirm_dlg", 
								{
									"title": "Play again?",
									"long_desc" : "Do you want to play again?",
									"event_type": "CUST_UI_CONFIRM",
									"event_params" : {
										"from": "h_player01_destroyed"
									}
								}
							]
					]
				]
			}
		],
		"CUST_UI_CONFIRM" : [
			{
				"id": "h_restart_confirmed",

				"actions": [
					"IF",
						["==", ["VAR", "from"], "h_player01_destroyed"],
						["SCRIPT", "new.restart_quest", {"quest_file" : "new/games/kill_all/kill_all_level01.json"}]
				]
			}
		]
	}

}