{
	"$schema": "../../../../../core/schemas/new/quest.schema.json",

	// Basic data
	"id" : "q_kill_all",
	"title" : "Kill All Game Demo",
	"description" : "Game where your objective is to kill all the enemies",
	"objective" : "Kill all your enemies",

	// What quests need to be loaded before this one
	"prereqs" : [],

	// What objects need to be cleaned first
	"cleanup" : {
		"processors": [],
		"maps": [], 
		"templates": [], 
		"entities": [], 
		"dialogs": [],
		"handlers": []
	},

	// What processors to load
	"processors" : [

		// For events processing
		["original.game_events_processor:GameEventsExProcessor", {"process" : ["QUEST_START", "DESTROYED", "CUST_UI_CONFIRM"]}],

		// For commands
		["new.command_system.generate_command_from_input_processor:GenerateCommandFromInputProcessor", {}],
		["new.command_system.generate_command_from_brain_processor:GenerateCommandFromBrainProcessor", {}],
		["new.command_system.generate_command_from_btree_processor:GenerateCommandFromBTreeProcessor", {}],
		["new.command_system.perform_command_processor:PerformCommandProcessor", {}],

		// For movement - projectile must have FlagDoMove in order to move and not fail to idle
		// ideally if some command can be in place to tell him to move in his brain - new_move_auto command
		["new.movement_system.perform_movement_processor:PerformMovementProcessor", {}],

		// For animation
		["new.animation_system.perform_movement_animation_processor:PerformMovementAnimationProcessor", {}],
		["new.animation_system.perform_action_animation_processor:PerformActionAnimationProcessor", {}],
		["new.animation_system.perform_action_idle_animation_processor:PerformActionIdleAnimationProcessor", {}],
		["new.animation_system.perform_idle_animation_processor:PerformIdleAnimationProcessor", {}],
		["new.animation_system.perform_expire_animation_processor:PerformExpireAnimationProcessor", {}],
		["new.animation_system.perform_frame_update_processor:PerformFrameUpdateProcessor", {}],

		// For projectile data generation
		["new.attack_system.generate_projectile_factory_data_processor:GenerateProjectileFactoryDataProcessor", {}],

		// For generation of projectile from factory and projectile data
		["new.factory_system.perform_factory_generation_processor:PerformFactoryGenerationProcessor", {}],

		// Adjust collision component of the entity - mainly for factory generated entities
		["new.collision_system.perform_adjust_collidable_processor:PerformAdjustCollidableProcessor", {}],

		// Adjust movable component of the entity - mainly for factory generated entities
		["new.movement_system.perform_adjust_movement_processor:PerformAdjustMovementProcessor", {}],

		// Adjust damaging component of the entity - mainly for factory generated entities
		["new.damage_system.perform_adjust_damaging_processor:PerformAdjustDamagingProcessor", {}],

		// For collisions
		["new.collision_system:GenerateCollisionsProcessor", {}],
		["new.collision_system:ResolveCollisionsProcessor", {}],
		
		// For damages
		["new.damage_system:GenerateDamageProcessor", {}],
		["new.damage_system:PerformDamageProcessor", {}],

		// For destroy
		["new.destroy_system.generate_destroy_on_collision_processor:GenerateDestroyOnCollisionProcessor", {}],
		["new.destroy_system.generate_destroy_on_stopped_movement_processor:GenerateDestroyOnStoppedMovementProcessor", {}],
		["new.destroy_system.generate_destroy_on_no_health_processor:GenerateDestroyOnNoHealthProcessor", {}],

		["new.destroy_system.perform_destroy_entities_processor:PerformDestroyEntitiesProcessor", {}],

		// For visual and sound effects
		["new.effects_system.generate_visual_fx_on_collision_processor:GenerateVisualFXOnCollisionProcessor", {}],
		["new.effects_system.generate_sound_fx_on_collision_processor:GenerateSoundFXOnCollisionProcessor", {}],

		// For displaying on screen
		["new.render_system.perform_clear_window_processor:PerformClearWindowProcessor", {}],
		["new.render_system.perform_clear_camera_processor:PerformClearCameraProcessor", {}],
		["new.render_system.perform_scroll_camera_processor:PerformScrollCameraProcessor", {}],
		["new.render_system.perform_render_map_processor:PerformRenderMapProcessor", {}],
		["new.render_system.generate_render_data_from_parent_processor:GenerateRenderDataFromParentProcessor", {}],
		["new.render_system.perform_render_model_processor:PerformRenderModelProcessor", {}],
		["new.render_system.perform_render_armed_weapon_processor:PerformRenderArmedWeaponProcessor", {}],
		["new.render_system.perform_render_armed_ammo_processor:PerformRenderArmedAmmoProcessor", {}],
		["new.render_system.perform_render_debug_info_processor:PerformRenderDebugInfoProcessor", {}],
		["new.render_system.perform_blit_camera_processor:PerformBlitCameraProcessor", {}],

		// Removals
		["new.movement_system.remove_flag_do_move_processor:RemoveFlagDoMoveProcessor", {}],
		["new.movement_system.remove_flag_adjust_movement_processor:RemoveFlagAdjustMovementProcessor", {}],
		["new.movement_system.remove_flag_has_stopped_movement_processor:RemoveFlagHasStoppedMovementProcessor", {}],

		["new.collision_system.remove_flag_has_collided_processor:RemoveFlagHasCollidedProcessor", {}],
		["new.collision_system.remove_flag_adjust_collidable_processor:RemoveFlagAdjustCollidableProcessor", {}],
		["new.attack_system.remove_flag_do_attack_processor:RemoveFlagDoAttackProcessor", {}],
		["new.animation_system.remove_flag_is_animation_action_frame_processor:RemoveFlagIsAnimationActionFrameProcessor", {}],
		["new.factory_system.remove_flag_create_from_factory_processor:RemoveFlagCreateFromFactoryProcessor", {}],
		["new.factory_system.remove_flag_generated_from_factory_processor:RemoveFlagGeneratedFromFactoryProcessor", {}],

		["new.damage_system.remove_flag_is_about_to_be_damaged_by_processor:RemoveFlagIsAboutToBeDamagedByProcessor", {}],
		["new.damage_system.remove_flag_was_damaged_by_processor:RemoveFlagWasDamagedByProcessor", {}],
		["new.damage_system.remove_flag_has_damaged_processor:RemoveFlagHasDamagedProcessor", {}],
		["new.damage_system.remove_flag_adjust_damaging_processor:RemoveFlagAdjustDamagingProcessor", {}],
		["new.damage_system.remove_flag_has_no_health_processor:RemoveFlagHasNoHealthProcessor", {}]

	],

	// What maps to load
	"maps" : [],
			
	// What dialogs to load
	"dialogs": [],

	// What templates to load
	"templates": [
				
		// By using template with parameters it is easy to define position of any entity
		{
			"id": "t_tile_pos",
			"vars": ["$tileX", "$tileY", "$map"],
			"components": [
				{"type" : "new.position:Position", "params" : {"tile_x" : "$tileX", "tile_y" : "$tileY", "map" : "$map"}}
			]
		}

	],

	// How to handle events
	"event_handlers" : {

		"QUEST_START" :[
			{
				"id": "h_start_game",
				
				"actions": [
					"SEQ",
					["SCRIPT", "new.load_image", {"image_file" : "weather_effects/rainy/frame_00_delay-0.06s.gif"}],
					["SCRIPT", "new.show_msg_window", {"html_text" : "Welcome to the <b>%quest_id</b> quest.<br/>Your goal is to kill all the enemies.<br/><br/>Good luck!"}],
					["SCRIPT", "new.load_quest", {"quest_file" : "new/games/kill_all/kill_all_level01.json"}]
				]
			}
		]
	}
}