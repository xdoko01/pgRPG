	// How to handle events
	"handlers": [
		[
			"QUEST_START",
			{
				"id": "ev_collect_coins",
				"actions": 	["SCRIPT", "new.show_msg_window", {"html_text" : "Welcome to %quest_id.<br/>Your goal is to collect coins with exact value of 500.<br/>Not less, not more!"}]
			}
		],
		[
			"SCORE",
			{
				"id": "ev_scored_exactly_500_points",
				"actions": [
					"IF",
						["==", ["VAR", "total"], 500],
						["SEQ",
							["SCRIPT", "new.show_msg_window", {"html_text" : "WOW! You have just reached the score %total!<br/>WELL DONE!"}],
							[
								"SCRIPT", 
								"new.show_confirm_dlg", 
								{
									"title": "Play again?",
									"long_desc" : "Do you want to play again?",
									"event_type": "CUST_UI_CONFIRM",
									"event_params" : {
										"from": "ev_scored_exactly_500_points"
									}
								}
							]
						]
				]
			}
		],
		[
			"SCORE",
			{
				"id": "ev_scored_more_than_500_points",
				"actions": [
					"IF",
						[">", ["VAR", "total"], 500],
						[
							"SCRIPT", 
							"new.show_confirm_dlg", 
							{
								"title": "Play again?",
								"long_desc" : "Bad luck, you are over the limit. Your score %total is greater than 500. Do you want to try again?",
								"event_type": "CUST_UI_CONFIRM",
								"event_params" : {
									"from": "ev_scored_more_than_500_points"
								}
							}
						]
				]
			}
		],
		[
			"CUST_UI_CONFIRM",
			{
				"id": "ev_restart_confirmed",
				"actions": [
					"IF",
						["OR",
							["==", ["VAR", "from"], "ev_scored_more_than_500_points"],
							["==", ["VAR", "from"], "ev_scored_exactly_500_points"]
						],
						["SCRIPT", "new.restart_quest", {"quest" : "new/games/collect_coins/collect_coins.json"}]
				]
			}
		],
		[
			"ITEM_PICKUP",
			{
				"id": "ev_first_golden_coin_picked_up",
				"actions": [
					"IF",
						["AND",
							["==", ["VAR", "category"], "items.coin.golden"],
							["==", ["VAR", "picker"], "player01"],
							["==", ["VAR", "amount_in_category"], 1]
						],
						["SEQ",
							["SCRIPT", "new.show_msg_window", {"html_text" : "You have picked your first golden coin. It counts for 100 points!"}]
						]
				]
			}
		],
		[
			"ITEM_PICKUP",
			{
				"id": "ev_first_silver_coin_picked_up",
				"actions": [
					"IF",
						["AND",
							["==", ["VAR", "category"], "items.coin.silver"],
							["==", ["VAR", "picker"], "player01"],
							["==", ["VAR", "amount_in_category"], 1]
						],
						["SEQ",
							["SCRIPT", "new.show_msg_window", {"html_text" : "You have picked your first silver coin. It counts for 20 points!"}]
						]
				]
			}
		],
		[
			"ITEM_PICKUP",
			{
				"id": "ev_first_copper_coin_picked_up",
				"actions": [
					"IF",
						["AND",
							["==", ["VAR", "category"], "items.coin.copper"],
							["==", ["VAR", "picker"], "player01"],
							["==", ["VAR", "amount_in_category"], 1]
						],
						["SEQ",
							["SCRIPT", "new.show_msg_window", {"html_text" : "You have picked your first copper coin. It counts for 5 points!"}]
						]
				]
			}
