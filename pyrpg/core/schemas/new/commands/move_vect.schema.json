{
	"$id": "move_vect.schema.json",
	"$schema": "https://json-schema.org/draft-07/schema",

	"title": "move_vect command",
	"description": "Move by specified vector (in px).",
	"markdownDescription": "*Move* by specified vector (in px).",

	"type": "array",
	"prefixItems": [
		{
			"title": "move_vect command",
			"description": "Move by specified vector (in px).",
			"markdownDescription": "*Move* by specified vector (in px).",		
			"enum": ["move_vect"]
		},
		{
			"title": "move_vect command parameters",
			"description": "vector (required), dt_comp (optional), absolute (optional)",
			"markdownDescription": "`vector` (required), `dt_comp` (optional), `absolute` (optional)",
			"type": "object",
			"required": ["vector"],
	
			"properties": {
				"vector": {
					"title": "Movement Vector in px",
					"description": "Movement vector in px",
					"markdownDescription": "Movement vector in px",
					"examples": [[-10, 0], [10, 20], [-10,-10]],
					"type": "array",
					"prefixItems": [
						{"title": "X-axis in px", "type": "integer"},
						{"title": "Y-axis in px", "type": "integer"}
					],
					"items": false
				},
				"dt_comp": {
					"title": "Delta-time Compensation",
					"description": "Specifies if the movement is compensated by current framerate. Default is True",
					"markdownDescription": "Specifies if the movement is compensated by current framerate. Default is `true`",
					"default": true,
					"examples": [true, false],
					"type": "boolean"
				},
				"absolute": {
					"title": "Do not apply velocity on the movement",
					"description": "Specifies if the movement is adjusted using velocity. Default is True",
					"markdownDescription": "Specifies if the movement is adjusted using velocity. Default is `true`",
					"default": true,
					"examples": [true, false],
					"type": "boolean"
				}
			}
		}
	],
	"items": false
}