{
	"$id": "entity.schema.json",
	"$schema": "https://json-schema.org/draft-07/schema",
	"description": "Schema validating entity",
	"title": "Entity Schema",

	"required": ["components"],
	"properties": {
		"id": {
			"description": "Entity unique id",
			"type": "string"
		},
		"templates": {
			"description": "Templates description",
			"type": "array",
			"items": {
			  "type": "string"
			},
			"minItems": 0,
			"uniqueItems": true
		},
		"components": {
			"description": "Components list",
			"type": "array",
			"items":{
				"$ref": "component.schema.json"
			},
			"minItems": 0,
			"uniqueItems": true
		}
	}
}
