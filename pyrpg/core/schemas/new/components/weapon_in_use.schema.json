{
	"$id": "weapon_in_use.schema.json",
	"$schema": "https://json-schema.org/draft-07/schema",

	"title": "WeaponInUse Component",
	"description": "Schema validating the WeaponInUse component.",

	"examples" : [
		{"type" : "new.weapon_in_use:WeaponInUse", "params" : {"type" : "bow"}}
	],

	"required": [ "type", "params"],
	"properties": {
		"type": {
			"description" : "Path to the component class.",
			"enum": [ "new.weapon_in_use:WeaponInUse" ]
		},
		"params": {
			"title": "Component parameters",
			"description" : "Parameters of the WeaponInUse component class - 'type', 'action', 'idle_action'.",
			"type": "object",
			"$ref": "#/$defs/cond_params",
			"required": ["type"],
			"properties": {
				"type" : {
					"$ref": "../definitions.schema.json#/definitions/entity_weapon_type"
				},
				"action" : {
					"$ref": "../definitions.schema.json#/definitions/entity_action"
				},
				"idle_action": {
					"$ref": "../definitions.schema.json#/definitions/entity_action"
				}

			}
		}
	},

	"$defs" : {
		"cond_params": {
			"description" : "Conditions for 'param' properties.",
			"anyOf": [true]
		}
	}
	
}