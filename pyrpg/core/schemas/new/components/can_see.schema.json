{
	"$id": "can_see.schema.json",
	"$schema": "https://json-schema.org/draft-07/schema",

	"title": "CanSee Component",
	"description": "Schema validating the CanSee component.",

	"examples" : [
		{"type" : "new.can_see:CanSee", "params" : {"angle": 90, "distance_px": 200}},
		{"type" : "new.can_see:CanSee", "params" : {"angle": 120, "distance_tiles" : 20}}
	],

	"required": [ "type", "params"],
	"properties": {
		"type": {
			"description" : "Path to the component class.",
			"enum": [ "new.can_see:CanSee" ]
		},
		"params": {
			"title": "Component parameters",
			"description" : "Parameters of the CanSee component class - 'angle', 'distance_px', 'distance_tiles', 'ent_in_sight'.",
			
			"type": "object",
			"required": ["angle"],
			"$ref": "#/$defs/cond_params",
			"properties": {
				"angle" : {
					"title": "Angle",
					"description": "View angle in degrees",
					"type": "integer",
					"minimum": 0,
					"maximum": 359
				},
				"distance_px" : {
					"title": "Distance",
					"description": "Max view distance in pixels.",
					"default" : 0,
					"type": "integer",
					"minimum": 0
				},
				"distance_tiles" : {
					"title": "Distance",
					"description": "Max view distance in tiles.",
					"type": "integer",
					"minimum": 0
				},
				"ent_in_sight": {
					"title": "Entities in Sight",
					"description": "List of entities which are being seen.",
					"default": [],
					"type": "array",
					"uniqueItems": true
				}
			}
		}
	},

	"$defs" : {
		"cond_params": {
			"description" : "Conditions for 'param' properties.",
			"anyOf": [true]
		}
	}

}