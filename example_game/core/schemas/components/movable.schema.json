{
	"$id": "movable.schema.json",
	"$schema": "https://json-schema.org/draft-07/schema",

	"title": "Movable Component",
	"description": "Schema validating the Movable component.",

	"examples" : [
		{"type" : "movable:Movable", "params" : {"velocity" : 10}},
		{"type" : "movable:Movable", "params" : {"velocity" : 5, "accelerate" : 2}},
		{"type" : "movable:Movable", "params" : {"velocity" : 50, "accelerate" : -2}}
	],

	"required": [ "type", "params"],
	"properties": {
		"type": {
			"description" : "Path to the component class.",
			"enum": [ "movable:Movable" ]
		},
		"params": {
			"title": "Component parameters",
			"description" : "Parameters of the Movable component class - 'velocity', 'accelerate'.",
			"type": "object",
			"required": ["velocity"],
			"$ref": "#/$defs/cond_params",
			"properties": {
				"velocity" : {
					"title": "Velocity",
					"description": "Speed of the movement.",
					"type": "integer",
					"exclusiveMinimum": 0
				},
				"accelerate" : {
					"title": "Acceleration Rate",
					"description": "Pace of acceleration.",
					"default" : 0,
					"type": "integer"
				}
			}
		}
	},

	"$defs" : {
		"cond_params": {
			"description" : "Conditions for 'param' properties.",
			"anyOf": [true]
		}
	}
	
}