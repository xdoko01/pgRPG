{
	"$id": "sound_fx_on_movement.schema.json",
	"$schema": "https://json-schema.org/draft-07/schema",

	"title": "SoundFXOnMovement Component",
	"description": "Schema validating the SoundFXOnMovement component.",

	"examples" : [
		{"type" : "sound_fx_on_movement:SoundFXOnMovement", "params" : {"sound" : "ouch.mp3"}}
	],

	"required": [ "type", "params"],
	"properties": {
		"type": {
			"description" : "Path to the component class.",
			"enum": [ "sound_fx_on_movement:SoundFXOnMovement" ]
		},
		"params": {
			"title": "Component parameters",
			"description" : "Parameters of the SoundFXOnMovement component class - 'sound' (required), 'volume' (optional).",
			"type": "object",
			"$ref": "#/$defs/cond_params",
			"required": ["sound"],
			"properties": {
				"sound" : {
					"$ref": "../definitions.schema.json#/definitions/sound_file"
				},
				"volume": {
					"title": "Volume",
					"description": "Playback volume of the sound effect. Default is 1.0.",
					"markdownDescription": "Playback volume of the sound effect. Default is `1.0`.",
					"examples": [0.1, 0.5, 0.8, 1.0],
					"default": 1.0,
					"type": "number",
					"minimum": 0.0,
					"maximum": 1.0
				}
			}
		}
	},

	"$defs" : {
		"cond_params": {
			"description" : "Conditions for 'param' properties.",
			"anyOf": [true]
		}
	}
	
}