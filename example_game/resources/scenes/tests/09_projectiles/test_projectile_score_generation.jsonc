{
	"$schema": "../../../../core/schemas/scene.schema.json",

	// Basic data
	"id" : "test_projectile_score_generation",
	"title" : "Test of Projectile Score Generation",
	"description" : "Test of Attack and Factory and Effect system - score of projectiles",
	"objective" : "POC of the Attack and Factory and Effect system",

	// What scenes need to be loaded before this one
	"prereqs" : [],

	// What objects need to be cleaned first
	"cleanup" : {
		"processors": [],
		"maps": [], 
		"templates": [], 
		"entities": [], 
		"dialogs": [],
		"handlers": []
	},

	// What processors to load
	"processors" : [

	//////////////////////////
	// Default processor group
	//////////////////////////

		// For commands
		["command_system:GenerateCommandFromInputProcessor", {}], // cmds from keyboard controlls
		["command_system:GenerateCommandFromMouseProcessor", {}], // cmds from mouse controlls - for inventory screen manipulation
		["command_system:GenerateCommandFromBrainProcessor", {}], // cmds from command generators such as behavior trees
		["command_system:PerformCommandProcessor", {}], // process the command queue

		// For movement
		["movement_system:PerformMovementProcessor", {}],

		// For animation
		["animation_system:PerformMovementAnimationProcessor", {}],
		["animation_system:PerformActionAnimationProcessor", {}], // once WeaponInUse component is used, this processor must be present
		["animation_system:PerformActionIdleAnimationProcessor", {}], // once WeaponInUse component is used, this processor must be present
		["animation_system:PerformIdleAnimationProcessor", {}],
		["animation_system:PerformExpireAnimationProcessor", {}], // once IsDestroyed component is used, this processor must be present
		["animation_system:PerformFrameUpdateProcessor", {}],

		// For projectile data generation
		["attack_system:GenerateProjectileFactoryDataProcessor", {}],
		["factory_system:PerformFactoryGenerationProcessor", {}],
		["collision_system:PerformAdjustCollidableProcessor", {}], // adjust collision component of the entity - mainly for factory generated entities
		["movement_system:PerformAdjustMovementProcessor", {}], // adjust movable component of the entity - mainly for factory generated entities
		["damage_system:PerformAdjustDamagingProcessor", {}], // (*NEW*) adjust damaging component of the entity - mainly for factory generated entities

		// For collisions
		["collision_system:GenerateCollisionsProcessor", {}],
		["collision_system:ResolveCollisionsProcessor", {}],
		
		// For damages
		["damage_system:GenerateDamageProcessor", {}],
		["damage_system:PerformDamageProcessor", {}],

		// (*NEW*) - For score
		["score_system:GenerateScoreOnDamageProcessor", {}],
		["score_system:GenerateScoreOnNoHealthProcessor", {}],
		["score_system:CalculateScoreProcessor", {}],
		
		// For destroy
		["destroy_system:GenerateDestroyOnCollisionProcessor", {}],
		["destroy_system:GenerateDestroyOnStoppedMovementProcessor", {}],
		["destroy_system:GenerateDestroyOnNoHealthProcessor", {}], // (*NEW*)
		["destroy_system:PerformDestroyEntitiesProcessor", {}],

		// For pickup
		["pickup_system:GeneratePickupProcessor", {}],
		["pickup_system:PerformPickupProcessor", {}],

		// For Arming of a Weapon
		["arm_weapon_system:GenerateArmWeaponProcessor", {}], // Following processor commented out for manual arming of the weapon and not automatic during pickup
		["arm_weapon_system:PerformArmWeaponProcessor", {}],

		// For Arming of an Ammo
		["arm_ammo_system:GenerateArmAmmoProcessor", {}],
		["arm_ammo_system:PerformArmAmmoProcessor", {}],

		// For dropping 
 		["drop_system:PerformDropProcessor", {}],

		// For Disarming of a weapon
		["arm_weapon_system:GenerateDisarmWeaponProcessor", {}],
		["arm_weapon_system:PerformDisarmWeaponProcessor", {}],

		// For Disarming of an Ammo
		["arm_ammo_system:GenerateDisarmAmmoProcessor", {}],
		["arm_ammo_system:PerformDisarmAmmoProcessor", {}],

		// For setting armed weapon into Use
		["arm_weapon_system:PerformSetWeaponIntoUseProcessor", {}],

		// For visual and sound effects
		["effects_system:GenerateSoundFXOnArmWeaponProcessor", {}],
		["effects_system:GenerateVisualFXOnCollisionProcessor", {}],
		["effects_system:GenerateSoundFXOnCollisionProcessor", {}],
		["effects_system:GenerateSoundFXOnDamageProcessor", {}], // (*NEW*)

		// For displaying on screen
		["render_system:PerformClearWindowProcessor", {}],
		["render_system:PerformClearCameraProcessor", {}],
		["render_system:PerformScrollCameraProcessor", {}],
		["render_system:PerformRenderMapProcessor", {}],
		["render_system:GenerateRenderDataFromParentProcessor", {}],
		["render_system:PerformRenderModelProcessor", {}],
		["render_system:PerformRenderArmedWeaponProcessor", {}],
		["render_system:PerformRenderArmedAmmoProcessor", {}],
		["render_system:PerformRenderDebugInfoProcessor", {}],
		["render_system:PerformRenderInventoryProcessor", {}], // for showing inventory window
		["render_system:PerformBlitCameraProcessor", {}],
		["render_system:PerformRenderMessagesProcessor", {}], // display messages

		// For events processing
		["event_system:GameEventsExProcessor", {"process" : ["SCENE_START"]}],

		// Removal of obsolete flags
		["movement_system:RemoveFlagDoMoveProcessor", {}],
		["movement_system:RemoveFlagAdjustMovementProcessor", {}],
		["movement_system:RemoveFlagHasStoppedMovementProcessor", {}],

		["collision_system:RemoveFlagHasCollidedProcessor", {}],
		["collision_system:RemoveFlagAdjustCollidableProcessor", {}],
		
		["attack_system:RemoveFlagDoAttackProcessor", {}],

		["animation_system:RemoveFlagIsAnimationActionFrameProcessor", {}],
		
		["factory_system:RemoveFlagCreateFromFactoryProcessor", {}],
		["factory_system:RemoveFlagGeneratedFromFactoryProcessor", {}],

		["pickup_system:RemoveFlagIsAboutToPickEntityProcessor", {}],
		["pickup_system:RemoveFlagHasPickedProcessor", {}],
		["pickup_system:RemoveFlagWasPickedByProcessor", {}],
			
		["arm_weapon_system:RemoveFlagIsAboutToArmWeaponProcessor", {}],
		["arm_weapon_system:RemoveFlagHasArmedWeaponProcessor", {}],
		["arm_weapon_system:RemoveFlagWasArmedAsWeaponByProcessor", {}],

		["arm_ammo_system:RemoveFlagIsAboutToArmAmmoProcessor", {}],
		["arm_ammo_system:RemoveFlagHasArmedAmmoProcessor", {}],
		["arm_ammo_system:RemoveFlagWasArmedAsAmmoByProcessor", {}],

		["drop_system:RemoveFlagIsAboutToDropEntityProcessor", {}],
		["drop_system:RemoveFlagHasDroppedProcessor", {}],
		["drop_system:RemoveFlagWasDroppedByProcessor", {}],

		["arm_weapon_system:RemoveFlagIsAboutToDisarmWeaponProcessor", {}],
		["arm_weapon_system:RemoveFlagHasDisarmedWeaponProcessor", {}],
		["arm_weapon_system:RemoveFlagWasDisarmedAsWeaponByProcessor", {}],

		["arm_ammo_system:RemoveFlagIsAboutToDisarmAmmoProcessor", {}],
		["arm_ammo_system:RemoveFlagHasDisarmedAmmoProcessor", {}],
		["arm_ammo_system:RemoveFlagWasDisarmedAsAmmoByProcessor", {}],

		["damage_system:RemoveFlagIsAboutToBeDamagedByProcessor", {}],
		["damage_system:RemoveFlagWasDamagedByProcessor", {}],
		["damage_system:RemoveFlagHasDamagedProcessor", {}], 
		["damage_system:RemoveFlagAdjustDamagingProcessor", {}],
		["damage_system:RemoveFlagHasNoHealthProcessor", {}], 

		["score_system.remove_flag_has_scored_processor:RemoveFlagHasScoredProcessor", {}],

		// For logging performance of processors - timed must be True for this processor to work
		//["debug_system.debug_processor_performance_processor:DebugProcessorPerformanceProcessor", {}]
	
		//////////////////////////
	// Pause processor group - initiated by pressing 'P' button
	//////////////////////////
		["pause", "render_system:PerformBlitPictureProcessor", {"filepath": "pause.png", "resize": true}]
	],

	// What maps to load
	"maps" : ["test_arena_sand"],
			
	// What dialogs to load
	"dialogs": [],

	// What templates to load
	"templates": [

		// By using template with parameters it is easy to define position of any entity
		{
			"id": "t_tile_pos",
			"vars": ["$tileX", "$tileY", "$map"],
			"components": [
				{"type" : "position:Position", "params" : {"tile_x" : "$tileX", "tile_y" : "$tileY", "map" : "$map"}}
			]
		}

	],

	// What entities to load
	"entities" : [
		
		{
			"id" : "w_spear",
			"templates" : [
				"thing/ammo_pack/thrust/regular_spear_generator($damage=35)", // ammo pack
				"thing/weapon/spear/spear", // weapon
				"t_tile_pos(5, 5, test_arena_sand)" // position template

			],
			"components" : [
			]
		},
		{
			"id" : "w_shovel",
			"templates" : [
				"thing/ammo_pack/thrust/regular_shovel_generator($damage=5)", // ammo pack
				"thing/weapon/spear/shovel", // weapon
				"t_tile_pos(6, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_crossbow",
			"templates" : [
				"thing/ammo_pack/thrust/crossbow_arrows_pack($arrows_count=100)", // ammo pack
				"thing/weapon/spear/crossbow", // weapon - must be loaded after ammo pack otherwise ammo pack renderable model will overwrite weapons renderable model
				"t_tile_pos(7, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_cane",
			"templates" : [
				"thing/ammo_pack/thrust/regular_cane_generator($damage=3)", // ammo pack
				"thing/weapon/spear/cane", // weapon
				"t_tile_pos(8, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_fireball_spell",
			"templates" : [
				"thing/ammo_pack/spellcast/fireball_spell_pack($count=100)", // ammo pack
				"thing/weapon/spell/fireball", // weapon
				"t_tile_pos(9, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_dagger",
			"templates" : [
				"thing/ammo_pack/slash/regular_dagger_generator($damage=20)", // ammo pack
				"thing/weapon/sword/dagger", // weapon
				"t_tile_pos(10, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_bow_metal_big",
			"templates" : [
				"thing/ammo_pack/shoot/iron_arrows_pack($arrows_count=20)", // ammo pack
				"thing/weapon/bow/bow_metal_big", // weapon
				"t_tile_pos(11, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_bow_metal",
			"templates" : [
				"thing/ammo_pack/shoot/iron_arrows_pack($arrows_count=20)", // ammo pack
				"thing/weapon/bow/bow_metal", // weapon
				"t_tile_pos(12, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_bow_recurved_blue",
			"templates" : [
				"thing/ammo_pack/shoot/iron_arrows_pack($arrows_count=20)", // ammo pack
				"thing/weapon/bow/bow_recurved_blue", // weapon
				"t_tile_pos(13, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_bow_recurved_red",
			"templates" : [
				"thing/ammo_pack/shoot/iron_arrows_pack($arrows_count=20)", // ammo pack
				"thing/weapon/bow/bow_recurved_red", // weapon
				"t_tile_pos(14, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_bow_recurved_wooden",
			"templates" : [
				"thing/ammo_pack/shoot/iron_arrows_pack($arrows_count=20)", // ammo pack
				"thing/weapon/bow/bow_recurved_wooden", // weapon
				"t_tile_pos(15, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_bow_recurved_yellow",
			"templates" : [
				"thing/ammo_pack/shoot/iron_arrows_pack($arrows_count=20)", // ammo pack
				"thing/weapon/bow/bow_recurved_yellow", // weapon
				"t_tile_pos(16, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_bow_wooden_big",
			"templates" : [
				"thing/ammo_pack/shoot/iron_arrows_pack($arrows_count=20)", // ammo pack
				"thing/weapon/bow/bow_wooden_big", // weapon
				"t_tile_pos(17, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_bow_wooden_skeleton",
			"templates" : [
				"thing/ammo_pack/shoot/iron_arrows_pack($arrows_count=20)", // ammo pack
				"thing/weapon/bow/bow_wooden_skeleton", // weapon
				"t_tile_pos(18, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_bow_wooden",
			"templates" : [
				"thing/ammo_pack/shoot/iron_arrows_pack($arrows_count=20)", // ammo pack
				"thing/weapon/bow/bow_wooden", // weapon
				"t_tile_pos(19, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_axe1",
			"templates" : [
				"thing/ammo_pack/slash/regular_axe1_generator($damage=20)", // ammo pack
				"thing/weapon/sword/axe1", // weapon
				"t_tile_pos(20, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_axe2",
			"templates" : [
				"thing/ammo_pack/slash/regular_axe2_generator($damage=20)", // ammo pack
				"thing/weapon/sword/axe2", // weapon
				"t_tile_pos(21, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_pickaxe",
			"templates" : [
				"thing/ammo_pack/slash/regular_pickaxe_generator($damage=20)", // ammo pack
				"thing/weapon/sword/pickaxe", // weapon
				"t_tile_pos(22, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_steelwand_fem",
			"templates" : [
				"thing/ammo_pack/slash/regular_steelwand_female_generator($damage=20)", // ammo pack
				"thing/weapon/sword/steelwand_female", // weapon
				"t_tile_pos(23, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_warhammer",
			"templates" : [
				"thing/ammo_pack/slash/regular_warhammer_generator($damage=20)", // ammo pack
				"thing/weapon/sword/warhammer", // weapon
				"t_tile_pos(24, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_woodwand_fem",
			"templates" : [
				"thing/ammo_pack/slash/regular_woodwand_female_generator($damage=20)", // ammo pack
				"thing/weapon/sword/woodwand_female", // weapon
				"t_tile_pos(25, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_woodwand_mal",
			"templates" : [
				"thing/ammo_pack/slash/regular_woodwand_male_generator($damage=20)", // ammo pack
				"thing/weapon/sword/woodwand_male", // weapon
				"t_tile_pos(26, 5, test_arena_sand)" // position template
			],
			"components" : [
			]
		},
		{
			"id" : "w_woodwand_mal_with_fireballs",
			"templates" : [
				"thing/ammo_pack/spellcast/fireball_spell_pack($count=100)", // ammo pack from spells
				"thing/weapon/sword/woodwand_male", // weapon
				"t_tile_pos(27, 5, test_arena_sand)" // position template
			],
			"components" : [
				// Override the ammoPack from spells to be available for sword weapon
				{"type" : "ammo_pack:AmmoPack", "params" : {"weapon" : "sword", "type" : "fireball_spells"}}
			]
		},

		{
			"id" : "player01",
			"templates" : [
				"model/body/male/human/white",
				"controls/default"
			],
			"components" : [

				{"type" : "debug:Debug", "params" : {"movement" : {"width" : 1, "color" : [0, 255, 0]}}},

				{
					"type" : "collidable:Collidable", 
					"params" :  {
						"x" : 15, "y" : 27, "dx" : 0, "dy" : 8
						//"accept_pos_fix_from_denylist" : ["ALL"] // no one can move the player - projectile cannot move the player. If missing projectile will move the player
					}
				},

				{"type" : "has_weapon:HasWeapon", "params" : {}},
				{"type" : "has_inventory:HasInventory", "params" : {}},

				{"type" : "has_score:HasScore", "params" : {}},

				{"type" : "position:Position", "params" : {"x" : 250, "y" : 250, "map" : "test_arena_sand"}},
				{"type" : "movable:Movable", "params" :  {"velocity" : 200}},
				{"type" : "camera:Camera", "params" : {"always_center": false, "screen_fill": true}}
			]
		},
		{
			"id" : "NPC01",
			"templates" : ["model/body/special/minotaur"],
			"components" : [
				{"type" : "debug:Debug", "params" : {}},

				// Move right - left
				{
					"type": "brain_ai:BrainAI", 
					"params": {
						"cmd_list" : [
							{"command": ["move_to_pos_px", {"pos": [1000,450]}]},
							{"command": ["move_to_pos_px", {"pos": [10,450]}]},
							{"type": "Goto", "jmp_to": 0}
						]
					}
				},

				{"type" : "destroy_on_no_health:DestroyOnNoHealth", "params" : {"ttl" : 10000}},
				{"type" : "scorable_on_damage:ScorableOnDamage", "params" : {"score" : 10}},

				{"type" : "damageable:Damageable", "params" : {"health" : 100}},

				{"type" : "position:Position", "params" : {"x" : 10, "y" : 450, "map" : "test_arena_sand"}},
				{"type" : "movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}}
			]
		},
		{
			"id" : "NPC02",
			"templates" : ["model/body/special/minotaur"],
			"components" : [
				{"type" : "debug:Debug", "params" : {}},

				{"type" : "scorable_on_no_health:ScorableOnNoHealth", "params" : {"score" : 1000}},
				{"type" : "destroy_on_no_health:DestroyOnNoHealth", "params" : {"ttl" : 10000}},

				{"type" : "damageable:Damageable", "params" : {"health" : 100}},

				{"type" : "position:Position", "params" : {"x" : 100, "y" : 100, "map" : "test_arena_sand"}},
				{"type" : "movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}}
			]
		}

	],

	// How to handle events
	"handlers": [
		[
			"SCENE_START",
			{
				"id": "ev_scene_start",
				"actions": 	[
					"SCRIPT",
					"show_msg_window", 
					{
						"title": "%filepath",
						"html_text": "<b>Scene ID:</b> %id<br/><b>Title:</b> %title<br/><b>Description:</b> %description<br/><b>Objective:</b> %objective<br/><br/><b>Stats:</b> %stats"
					}
				]
			}
		]
	]
}