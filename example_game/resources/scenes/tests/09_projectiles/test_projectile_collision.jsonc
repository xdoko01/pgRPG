{
	"$schema": "../../../../core/schemas/scene.schema.json",

	// Basic data
	"id" : "test_projectile_collision",
	"title" : "Test of Projectile Collision",
	"description" : "Test of Attack and Factory and Effect system - collision of projectile",
	"objective" : "POC of the new Attack and Factory and Effect system",

	// What quests need to be loaded before this one
	"prereqs" : [],

	// What objects need to be cleaned first
	"cleanup" : {
		"processors": [],
		"maps": [], 
		"templates": [], 
		"entities": [], 
		"dialogs": [],
		"handlers": []
	},

	// What processors to load
	"processors" : [

		// For commands
		["command_system.generate_command_from_input_processor:GenerateCommandFromInputProcessor", {}],
		["command_system.generate_command_from_brain_processor:GenerateCommandFromBrainProcessor", {}],
		["command_system.perform_command_processor:PerformCommandProcessor", {}],

		// For movement - projectile must have FlagDoMove in order to move and not fail to idle
		// ideally if some command can be in place to tell him to move in his brain - new_move_auto command
		["movement_system.perform_movement_processor:PerformMovementProcessor", {}],

		// For animation
		["animation_system.perform_movement_animation_processor:PerformMovementAnimationProcessor", {}],
		["animation_system.perform_action_animation_processor:PerformActionAnimationProcessor", {}],
		["animation_system.perform_action_idle_animation_processor:PerformActionIdleAnimationProcessor", {}],
		["animation_system.perform_idle_animation_processor:PerformIdleAnimationProcessor", {}],
		["animation_system.perform_expire_animation_processor:PerformExpireAnimationProcessor", {}],
		["animation_system.perform_frame_update_processor:PerformFrameUpdateProcessor", {}],

		// NEW - For projectile data generation
		["attack_system.generate_projectile_factory_data_processor:GenerateProjectileFactoryDataProcessor", {}],

		// NEW - For generation of projectile from factory and projectile data
		["new.factory_system.perform_factory_generation_processor:PerformFactoryGenerationProcessor", {}],

		// NEW - adjust collision component of the entity - mainly for factory generated entities
		["new.collision_system.perform_adjust_collidable_processor:PerformAdjustCollidableProcessor", {}],

		// NEW - adjust movable component of the entity - mainly for factory generated entities
		["movement_system.perform_adjust_movement_processor:PerformAdjustMovementProcessor", {}],

		// For collisions
		["new.collision_system:GenerateCollisionsProcessor", {}],
		["new.collision_system:ResolveCollisionsProcessor", {}],
		
		// For destroy
		["new.destroy_system.generate_destroy_on_collision_processor:GenerateDestroyOnCollisionProcessor", {}],
		["new.destroy_system.generate_destroy_on_stopped_movement_processor:GenerateDestroyOnStoppedMovementProcessor", {}],
		["new.destroy_system.perform_destroy_entities_processor:PerformDestroyEntitiesProcessor", {}],

		// For visual and sound effects
		["new.effects_system.generate_visual_fx_on_collision_processor:GenerateVisualFXOnCollisionProcessor", {}],
		["new.effects_system.generate_sound_fx_on_collision_processor:GenerateSoundFXOnCollisionProcessor", {}],

		// For displaying on screen
		["render_system.perform_clear_window_processor:PerformClearWindowProcessor", {}],
		["render_system.perform_clear_camera_processor:PerformClearCameraProcessor", {}],
		["render_system.perform_scroll_camera_processor:PerformScrollCameraProcessor", {}],
		["render_system.perform_render_map_processor:PerformRenderMapProcessor", {}],
		["render_system.generate_render_data_from_parent_processor:GenerateRenderDataFromParentProcessor", {}],
		["render_system.perform_render_model_processor:PerformRenderModelProcessor", {}],
		["render_system.perform_render_armed_weapon_processor:PerformRenderArmedWeaponProcessor", {}],
		["render_system.perform_render_armed_ammo_processor:PerformRenderArmedAmmoProcessor", {}],
		["render_system.perform_render_debug_info_processor:PerformRenderDebugInfoProcessor", {}],
		["render_system.perform_blit_camera_processor:PerformBlitCameraProcessor", {}],


		// For events processing - display the dialog on the start of the quest - after first game screen is generated
		["event_system.game_events_processor:GameEventsExProcessor", {"process" : ["QUEST_START"]}],

		// Removal of obsolete flags
		["movement_system.remove_flag_do_move_processor:RemoveFlagDoMoveProcessor", {}],

		["movement_system.remove_flag_adjust_movement_processor:RemoveFlagAdjustMovementProcessor", {}],
		["movement_system.remove_flag_has_stopped_movement_processor:RemoveFlagHasStoppedMovementProcessor", {}],

		["new.collision_system.remove_flag_has_collided_processor:RemoveFlagHasCollidedProcessor", {}],
		["new.collision_system.remove_flag_adjust_collidable_processor:RemoveFlagAdjustCollidableProcessor", {}],
		["attack_system.remove_flag_do_attack_processor:RemoveFlagDoAttackProcessor", {}],
		["animation_system.remove_flag_is_animation_action_frame_processor:RemoveFlagIsAnimationActionFrameProcessor", {}],
		["new.factory_system.remove_flag_create_from_factory_processor:RemoveFlagCreateFromFactoryProcessor", {}],
		["new.factory_system.remove_flag_generated_from_factory_processor:RemoveFlagGeneratedFromFactoryProcessor", {}]

		// For logging performance of processors - timed must be True for this processor to work
		//["debug_system.debug_processor_performance_processor:DebugProcessorPerformanceProcessor", {}]
	],

	// What maps to load
	"maps" : ["test_arena_sand"],

	// What dialogs to load
	"dialogs": [],

	// What templates to load
	"templates": [],

	// What entities to load
	"entities" : [
		
		// Spear
		{
			"id" : "spear_generator",
			"templates" : [], // no model needed
			"components" : [
				{"type" : "ammo_pack:AmmoPack", "params" : {"weapon" : "spear", "type" : "regular_spear_thrust"}},
				{
					"type" : "new.factory:Factory", 
					"params" : {
						"prescription" : {
							"templates" : [], // Only collision zone is created, no sprite.
							"components" : [
								{"type" : "debug:Debug", "params" : {}},

								{
									"type" : "collidable:Collidable", 
									"params" : {
										"x" : 8, "y" : 8, 
										"accept_pos_fix_from_denylist" : ["ALL"], // never change position of the sword slash upon collision with anybody
										"apply_pos_fix_to_denylist" : ["ALL"] // never change position of the entity that was slashed
										}},
								
								//{"type" : "new.destroy_on_collision:DestroyOnCollision", "params" : {"ttl" : 0}},
								{"type" : "new.is_destroyed:IsDestroyed", "params" : {"ttl" : 0}},

								{"type" : "new.visual_fx_on_collision:VisualFXOnCollision", "params" : {"effect" : "new/effects/explosion"}},
								{"type" : "new.sound_fx_on_collision:SoundFXOnCollision", "params" : {"sound" : "hurt/1.mp3"}}

							]
						}
					}
				}
			]
		},

		{
			"id" : "long_spear",
			"templates" : ["model/weapon/thrust/spear"],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type" : "sword",	"max_projectiles" : 5}}
			]
		},


		// Dagger
		{
			"id" : "sword_generator",
			"templates" : ["model/ammo_pack/shoot/wooden_arrows_pack"],
			"components" : [
				{"type" : "ammo_pack:AmmoPack", "params" : {"weapon" : "sword", "type" : "regular_sword_slash"}},
				{
					"type" : "new.factory:Factory", 
					"params" : {
						"prescription" : {
							"templates" : [], // Only collision zone is created, no sprite.
							"components" : [
								{"type" : "debug:Debug", "params" : {}},

								{
									"type" : "collidable:Collidable", 
									"params" : {
										"x" : 8, "y" : 8, 
										"accept_pos_fix_from_denylist" : ["ALL"], // never change position of the sword slash upon collision with anybody
										"apply_pos_fix_to_denylist" : ["ALL"] // never change position of the entity that was slashed
										}},
								
								//{"type" : "new.destroy_on_collision:DestroyOnCollision", "params" : {"ttl" : 0}},
								{"type" : "new.is_destroyed:IsDestroyed", "params" : {"ttl" : 0}},

								{"type" : "new.visual_fx_on_collision:VisualFXOnCollision", "params" : {"effect" : "new/effects/explosion"}},
								{"type" : "new.sound_fx_on_collision:SoundFXOnCollision", "params" : {"sound" : "hurt/1.mp3"}}


							]
						}
					}
				}
			]
		},

		{
			"id" : "long_sword",
			"templates" : ["model/weapon/slash/dagger"],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type" : "spear",	"max_projectiles" : 5}}
			]
		},


		// wooden_arrows_pack AmmoPack is Factory for generation of arrows
		{
			"id" : "wooden_arrows_pack",
			"templates" : ["model/ammo_pack/shoot/wooden_arrows_pack"],
			"components" : [
				{"type" : "ammo_pack:AmmoPack", "params" : {"weapon" : "bow", "type" : "wooden_arrows_pack"}},
				{
					"type" : "new.factory:Factory", 
					"params" : {
						"prescription" : {
							"id": "wooden_arrow_pack_arrow",
							"templates" : ["model/ammo/shoot/wooden_arrow"],
							"components" : [
								{"type" : "debug:Debug", "params" : {}},

								{
									"type" : "brain_ai:BrainAI",
									"params" : {
										"cmd_list" : [
											{"command": ["move_auto", {}]} // duration is not specified so the movement is infinite
										]
									}
								},

								{"type" : "movable:Movable", "params" :  {"velocity" : 500, "accelerate" : -3}},
								{"type" : "collidable:Collidable", "params" : {"x" : 8, "y" : 8, "accept_pos_fix_from_denylist" : ["ALL"]}},
								{"type" : "new.destroy_on_collision:DestroyOnCollision", "params" : {"ttl" : 0}},
								{"type" : "new.destroy_on_no_movement:DestroyOnNoMovement", "params" : {"ttl" : 0}},
								
								{"type" : "new.visual_fx_on_collision:VisualFXOnCollision", "params" : {"effect" : "new/effects/explosion"}},
								{"type" : "new.sound_fx_on_collision:SoundFXOnCollision", "params" : {"sound" : "hurt/1.mp3"}}


							]
						}
					}
				}
			]
		},

		{
			"id" : "wooden_bow",
			"templates" : ["model/weapon/shoot/bow_wooden_big"],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type" : "bow",	"max_projectiles" : 5}}
			]
		},

		{
			"id" : "spell_pack",
			"templates" : [],
			"components" : [
				{"type" : "ammo_pack:AmmoPack", "params" : {"weapon" : "spell", "type" : "fireball"}},
				{
					"type" : "new.factory:Factory", 
					"params" : {
						"prescription" : {
							"id": "spell_pack_arrow",
							"templates" : ["model/ammo/shoot/wooden_arrow"],
							"components" : [
								{"type" : "debug:Debug", "params" : {}},

								{
									"type" : "brain_ai:BrainAI",
									"params" : {
										"cmd_list" : [
											{"command": ["move_auto", {}]} // duration is not specified so the movement is infinite
										]
									}
								},

								{"type" : "movable:Movable", "params" :  {"velocity" : 500}},
								{"type" : "collidable:Collidable", "params" : {"x" : 8, "y" : 8, "accept_pos_fix_from_denylist" : ["ALL"]}},
								{"type" : "new.destroy_on_collision:DestroyOnCollision", "params" : {"ttl" : 0}},
								
								{"type" : "new.visual_fx_on_collision:VisualFXOnCollision", "params" : {"effect" : "new/effects/explosion"}},
								{"type" : "new.sound_fx_on_collision:SoundFXOnCollision", "params" : {"sound" : "hurt/1.mp3"}}


							]
						}
					}
				}
			]
		},

		{
			"id" : "spell_ability",
			"templates" : [],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type" : "spell",	"max_projectiles" : 5}}
			]
		},

		{
			"id" : "player01",
			"templates" : [
				"model/body/male/human/white", // model template
				"controls/default" // control template
			],
			"components" : [

				{"type" : "debug:Debug", "params" : {"movement" : {"width" : 1, "color" : [0, 255, 0]}}},

				{
					"type" : "collidable:Collidable", 
					"params" :  {
						"x" : 15, "y" : 27, "dx" : 0, "dy" : 8//,
						//"accept_pos_fix_from_denylist" : ["ALL"] // no one can move the player - projectile cannot move the player. If missing projectile will move the player
					}
				},

				// Bow is armed and preselected as the active weapon
				{"type" : "has_weapon:HasWeapon", "params" : {
					"weapons" : {
						"bow" : {"weapon" : "wooden_bow", "generator" : "wooden_arrows_pack"},
						"sword" : {"weapon" : "long_sword", "generator" : "sword_generator"},
						"spear" : {"weapon" : "long_spear", "generator" : "spear_generator"},
						"spell" : {"weapon" : "spell_ability", "generator" : "spell_pack"}

					}
				}},

				//{"type" : "weapon_in_use:WeaponInUse", "params" :  {"type" : "bow"}},
				{"type" : "weapon_in_use:WeaponInUse", "params" :  {"type" : "bow"}},

				{"type" : "position:Position", "params" : {"x" : 250, "y" : 250, "map" : "test_arena_sand"}},
				{"type" : "movable:Movable", "params" :  {"velocity" : 200}},
				{"type" : "camera:Camera", "params" : {"always_center": false, "screen_pos_x" : 0, "screen_pos_y" : 0, "screen_width" : 640, "screen_height" : 480}}
			]
		},
		{
			"id" : "NPC01",
			"templates" : ["model/body/special/minotaur"],
			"components" : [
				{"type" : "debug:Debug", "params" : {}},

				// Move right - left
				{
					"type" : "brain_ai:BrainAI",
					"params" : {
						"cmd_list" : [
							{"command": ["move_to_pos_px", {"pos": [1000, 450]}]},
							{"command": ["move_to_pos_px", {"pos": [10, 450]}]},
							{"type": "Goto", "jmp_to": 0}
						]
					}
				},

				{"type" : "position:Position", "params" : {"x" : 10, "y" : 450, "map" : "test_arena_sand"}},
				{"type" : "movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}}
			]
		},
		{
			"id" : "NPC02",
			"templates" : ["model/body/special/minotaur"],
			"components" : [
				{"type" : "debug:Debug", "params" : {}},

				{"type" : "position:Position", "params" : {"x" : 100, "y" : 100, "map" : "test_arena_sand"}},
				{"type" : "movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}}
			]
		}

	],

	// How to handle events
	"handlers": [
		[
			"QUEST_START",
			{
				"id": "ev_quest_start",
				"actions": 	[
					"SCRIPT",
					"show_msg_window", 
					{
						"title": "%filepath",
						"html_text": "<b>Quest ID:</b> %id<br/><b>Title:</b> %title<br/><b>Description:</b> %description<br/><b>Objective:</b> %objective<br/><br/><b>Stats:</b> %stats"
					}
				]
			}
		]
	]
}