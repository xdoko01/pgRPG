{
	// JSON Schema for validation of the game parameters
	"$schema": "../../../../core/schemas/scene.schema.json",

	// Basic data
	"id" : "test_projectile_generation",
	"title" : "Test of Projectile Generation",
	"description" : "Test of Attack and Factory system - generation of projectile",
	"objective" : "POC of the new Attack and Factory system",

	// What quests need to be loaded before this one
	"prereqs" : [],

	// What objects need to be cleaned first
	"cleanup" : {
		"processors": [],
		"maps": [], 
		"templates": [], 
		"entities": [], 
		"dialogs": [],
		"handlers": []
	},

	// What processors to load
	"processors" : [

		// For commands
		["command_system.generate_command_from_input_processor:GenerateCommandFromInputProcessor", {}],
		["command_system.generate_command_from_brain_processor:GenerateCommandFromBrainProcessor", {}], // Also projectile needs to have brain in order to move
		["command_system.perform_command_processor:PerformCommandProcessor", {}],

		// For movement - projectile must have FlagDoMove in order to move and not fail to idle
		// ideally if some command can be in place to tell him to move in his brain - new_move_auto command
		["movement_system.perform_movement_processor:PerformMovementProcessor", {}],

		// For animation
		["new.animation_system.perform_movement_animation_processor:PerformMovementAnimationProcessor", {}],
		["new.animation_system.perform_action_animation_processor:PerformActionAnimationProcessor", {}],
		["new.animation_system.perform_action_idle_animation_processor:PerformActionIdleAnimationProcessor", {}],
		["new.animation_system.perform_idle_animation_processor:PerformIdleAnimationProcessor", {}],
		["new.animation_system.perform_frame_update_processor:PerformFrameUpdateProcessor", {}],

		// NEW - For projectile data generation
		["new.attack_system.generate_projectile_factory_data_processor:GenerateProjectileFactoryDataProcessor", {}],

		// NEW - For generation of projectile from factory and projectile data
		["new.factory_system.perform_factory_generation_processor:PerformFactoryGenerationProcessor", {}],

		// For displaying on screen
		["render_system.perform_clear_window_processor:PerformClearWindowProcessor", {}],
		["render_system.perform_clear_camera_processor:PerformClearCameraProcessor", {}],
		["render_system.perform_scroll_camera_processor:PerformScrollCameraProcessor", {}],
		["render_system.perform_render_map_processor:PerformRenderMapProcessor", {}],
		["render_system.generate_render_data_from_parent_processor:GenerateRenderDataFromParentProcessor", {}],
		["render_system.perform_render_model_processor:PerformRenderModelProcessor", {}],
		["render_system.perform_render_armed_weapon_processor:PerformRenderArmedWeaponProcessor", {}],
		["render_system.perform_render_armed_ammo_processor:PerformRenderArmedAmmoProcessor", {}],
		["render_system.perform_render_debug_info_processor:PerformRenderDebugInfoProcessor", {}],
		["render_system.perform_blit_camera_processor:PerformBlitCameraProcessor", {}],

		// For events processing - display the dialog on the start of the quest - after first game screen is generated
		["event_system.game_events_processor:GameEventsExProcessor", {"process" : ["QUEST_START"]}],

		// Removal of obsolete flags
		["movement_system.remove_flag_do_move_processor:RemoveFlagDoMoveProcessor", {}],
		["new.attack_system.remove_flag_do_attack_processor:RemoveFlagDoAttackProcessor", {}],
		["new.animation_system.remove_flag_is_animation_action_frame_processor:RemoveFlagIsAnimationActionFrameProcessor", {}],
		["new.factory_system.remove_flag_create_from_factory_processor:RemoveFlagCreateFromFactoryProcessor", {}], // NEW - for removing flag for generation of projectile
		["new.factory_system.remove_flag_generated_from_factory_processor:RemoveFlagGeneratedFromFactoryProcessor", {}]

	],

	// What maps to load
	"maps" : ["test_arena_sand"],
			
	// What dialogs to load
	"dialogs": [],

	// What templates to load
	"templates": [],

	// What entities to load
	"entities" : [
		
		// AmmoPack is Factory for generation of arrows
		{
			"id" : "wooden_arrows_pack",
			"templates" : ["model/ammo_pack/shoot/wooden_arrows_pack"],
			"components" : [
				{"type" : "new.ammo_pack:AmmoPack", "params" : {"weapon" : "bow", "type" : "wooden_arrows_pack"}},
				{
					"type" : "new.factory:Factory", 
					"params" : {
						"prescription" : {
							"id" : "wooden_arrow",
							"templates" : ["model/ammo/shoot/wooden_arrow"],
							"components" : [
								{"type" : "new.debug:Debug", "params" : {}},

								{
									"type" : "new.brain_ai:BrainAI",
									"params" : {
										"cmd_list" : [
											{"command": ["move_auto", {"duration_ms": 3000}]}
										]
									}
								},
		
								//{"type" : "LinearMotion", "params" : {"speed" : 200}},
								//{"type" : "Motion", "params" : {"dx" : 0, "dy" : 0}},
								//{"type" : "Damaging", "params" : {"damage" : 5}},
								//{"type" : "DeleteOnCollision", "params" : {}},

								{"type" : "movable:Movable", "params" :  {"velocity" : 100}},
								{"type" : "new.collidable:Collidable", "params" : {"x" : 8, "y" : 8}}
							]
						} 
					}
				}
			]
		},

		{
			"id" : "wooden_bow",
			"templates" : ["model/weapon/shoot/bow_wooden_big"],
			"components" : [
				{"type" : "new.weapon:Weapon", "params" : {"type" : "bow",	"max_projectiles" : 5}}
			]
		},

		{
			"id" : "player01",
			"templates" : [
				"new/model/body/male/human/white",
				"new/controls/default"
			],
			"components" : [

				{"type" : "new.debug:Debug", "params" : {"movement" : {"width" : 1, "color" : [0, 255, 0]}}},
				{"type" : "new.collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}},


				// Bow is armed and preselected as the active weapon
				{"type" : "new.has_weapon:HasWeapon", "params" : {
					"weapons" : {
						"bow" : {"weapon" : "wooden_bow", "generator" : "wooden_arrows_pack"}
					}
				}},

				{"type" : "new.weapon_in_use:WeaponInUse", "params" :  {"type" : "bow"}},

				{"type" : "position:Position", "params" : {"x" : 250, "y" : 250, "map" : "test_arena_sand"}},
				{"type" : "movable:Movable", "params" :  {"velocity" : 200}},
				{"type" : "camera:Camera", "params" : {"always_center": false, "screen_pos_x" : 0, "screen_pos_y" : 0, "screen_width" : 640, "screen_height" : 480}}
			]
		}
	],

	// How to handle events
	"handlers": [
		[
			"QUEST_START",
			{
				"id": "ev_quest_start",
				"actions": 	[
					"SCRIPT",
					"show_msg_window", 
					{
						"title": "%filepath",
						"html_text": "<b>Quest ID:</b> %id<br/><b>Title:</b> %title<br/><b>Description:</b> %description<br/><b>Objective:</b> %objective<br/><br/><b>Stats:</b> %stats"
					}
				]
			}
		]
	]
}