{
	// JSON Schema for validation of the game parameters
	"$schema": "../../../../core/schemas/scene.schema.json",

	// Basic data
	"id" : "test_arm_weapon_02",
	"title" : "Arming weapon using action key on Wepon in inventory window + dropping + pause + messages as a reaction on event (script) + arming sound",
	"description" : "Arming weapon using action key on Wepon in inventory window - using inventory_action command",
	"objective" : "POC of arming through inventory",

	// What scenes need to be loaded before this one
	"prereqs" : [],

	// What objects need to be cleaned first
	"cleanup" : {
		"processors": [],
		"maps": [], 
		"templates": [], 
		"entities": [], 
		"dialogs": [],
		"handlers": []
	},

	// What processors to load
	"processors" : [

	// Default processor group
		// For commands
			["command_system.generate_command_from_input_processor:GenerateCommandFromInputProcessor", {}],
			["command_system.generate_command_from_brain_processor:GenerateCommandFromBrainProcessor", {}],

			// Control mouse actions in inventory
			["command_system.generate_command_from_mouse_processor:GenerateCommandFromMouseProcessor", {}],

			["command_system.perform_command_processor:PerformCommandProcessor", {}],

		// For movement
			["movement_system.perform_movement_processor:PerformMovementProcessor", {}],

		// For animation
			["animation_system.perform_movement_animation_processor:PerformMovementAnimationProcessor", {}],
			["animation_system.perform_idle_animation_processor:PerformIdleAnimationProcessor", {}],
			["animation_system.perform_frame_update_processor:PerformFrameUpdateProcessor", {}],

		// For animation
			["animation_system.perform_movement_animation_processor:PerformMovementAnimationProcessor", {}],
			["animation_system.perform_action_animation_processor:PerformActionAnimationProcessor", {}], // once WeaponInUse component is used, this processor must be present
			["animation_system.perform_action_idle_animation_processor:PerformActionIdleAnimationProcessor", {}], // once WeaponInUse component is used, this processor must be present
			["animation_system.perform_idle_animation_processor:PerformIdleAnimationProcessor", {}],
			["animation_system.perform_expire_animation_processor:PerformExpireAnimationProcessor", {}], // once IsDestroyed component is used, this processor must be present
			["animation_system.perform_frame_update_processor:PerformFrameUpdateProcessor", {}],

		// For collisions
			["collision_system.generate_collisions_processor:GenerateCollisionsOptimizedProcessor", {}],
			["collision_system.resolve_collisions_processor:ResolveCollisionsOptimizedProcessor", {}],

		// For pickup
			["pickup_system.generate_pickup_processor:GeneratePickupProcessor", {}],
			["pickup_system.perform_pickup_processor:PerformPickupProcessor", {}],

		// For dropping 
 			["drop_system.perform_drop_processor:PerformDropProcessor", {}],

		// For Arming of a Weapon
			// Following processor commented out for manual arming of the weapon and not automatic during pickup
			["arm_weapon_system.generate_arm_weapon_processor:GenerateArmWeaponProcessor", {}],
			["arm_weapon_system.perform_arm_weapon_processor:PerformArmWeaponProcessor", {}],

		// For arming sound effects
			["effects_system.generate_sound_fx_on_arm_weapon_processor:GenerateSoundFXOnArmWeaponProcessor", {}],

		// For Disarming of a weapon
			["arm_weapon_system.generate_disarm_weapon_processor:GenerateDisarmWeaponProcessor", {}],
			["arm_weapon_system.perform_disarm_weapon_processor:PerformDisarmWeaponProcessor", {}],

		// For displaying
			["render_system.perform_clear_window_processor:PerformClearWindowProcessor", {}],
			["render_system.perform_clear_camera_processor:PerformClearCameraProcessor", {}],
			["render_system.perform_scroll_camera_processor:PerformScrollCameraProcessor", {}],
			["render_system.perform_render_map_processor:PerformRenderMapProcessor", {}],
			["render_system.generate_render_data_from_parent_processor:GenerateRenderDataFromParentProcessor", {}],
			["render_system.perform_render_model_processor:PerformRenderModelProcessor", {}],
			["render_system.perform_render_armed_weapon_processor:PerformRenderArmedWeaponProcessor", {}],

			["render_system.perform_render_debug_info_processor:PerformRenderDebugInfoProcessor", {}],
			// Processor for displaying the inventory window
			["render_system.perform_render_inventory_processor:PerformRenderInventoryProcessor", {}],
	
			["render_system.perform_blit_camera_processor:PerformBlitCameraProcessor", {}],

			// Messages must be printed after PerformBlitCameraProcessor otherwise overwritten by the camera window immediatelly
			["render_system.perform_render_messages_processor:PerformRenderMessagesProcessor", {}],

		// For events processing - display the dialog on the start of the scene - after first game screen is generated
			["event_system.game_events_processor:GameEventsExProcessor", {"process" : ["SCENE_START", "WEAPON_ARMED"]}],

		// For clearing of processing of movements and collisions and pickups
			["movement_system.remove_flag_do_move_processor:RemoveFlagDoMoveProcessor", {}],

			["collision_system.remove_flag_has_collided_processor:RemoveFlagHasCollidedProcessor", {}],

			["attack_system.remove_flag_do_attack_processor:RemoveFlagDoAttackProcessor", {}], // if attack command is used, this processor must be planned. Otherwise no movement will happen after pressing the attack button

			["animation_system.remove_flag_is_animation_action_frame_processor:RemoveFlagIsAnimationActionFrameProcessor", {}],

			["pickup_system.remove_flag_is_about_to_pick_entity_processor:RemoveFlagIsAboutToPickEntityProcessor", {}],
			["pickup_system.remove_flag_has_picked_processor:RemoveFlagHasPickedProcessor", {}],
			["pickup_system.remove_flag_was_picked_by_processor:RemoveFlagWasPickedByProcessor", {}],

			["arm_weapon_system.remove_flag_is_about_to_arm_weapon_processor:RemoveFlagIsAboutToArmWeaponProcessor", {}],
			["arm_weapon_system.remove_flag_has_armed_weapon_processor:RemoveFlagHasArmedWeaponProcessor", {}],
			["arm_weapon_system.remove_flag_was_armed_as_weapon_by_processor:RemoveFlagWasArmedAsWeaponByProcessor", {}],

			["drop_system.remove_flag_is_about_to_drop_entity_processor:RemoveFlagIsAboutToDropEntityProcessor", {}],
			["drop_system.remove_flag_has_dropped_processor:RemoveFlagHasDroppedProcessor", {}],
			["drop_system.remove_flag_was_dropped_by_processor:RemoveFlagWasDroppedByProcessor", {}],

			["arm_weapon_system.remove_flag_is_about_to_disarm_weapon_processor:RemoveFlagIsAboutToDisarmWeaponProcessor", {}],
			["arm_weapon_system.remove_flag_has_disarmed_weapon_processor:RemoveFlagHasDisarmedWeaponProcessor", {}],
			["arm_weapon_system.remove_flag_was_disarmed_as_weapon_by_processor:RemoveFlagWasDisarmedAsWeaponByProcessor", {}],


	// Pause processor group - initiated by pressing 'P' button
			["pause", "render_system.perform_blit_picture_processor:PerformBlitPictureProcessor", {"filepath": "pause.png", "resize": true}]

	],
	
	// What maps to load
	"maps" : ["test_arena_sand"],

	// What dialogs to load
	"dialogs" : [],

	// What templates to load
	"templates": [
		// By using template with parameters it is easy to define position of any entity
		{
			"id": "t_tile_pos",
			"vars": ["$tileX", "$tileY", "$map"],
			"components": [
				{"type" : "position:Position", "params" : {"tile_x" : "$tileX", "tile_y" : "$tileY", "map" : "$map"}}
			]
		},
		{
			"id" : "t_pickable_item",
			"components" : [
				{"type" : "debug:Debug", "params" : {}},
				{"type" : "pickable:Pickable", "params" :  {}},
				{"type" : "collidable:Collidable", "params" :  {"x" : 15, "y" : 15, "dx" : 0, "dy" : 8}}
			]
		}
	],

	// What entities to load
	"entities" : [
		{
			"id" : "player01",
			"templates" : [
				"model/body/male/human/dark2", // model template
				"controls/game_default",   // controls template
				"t_tile_pos(5, 5, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "debug:Debug", "params" : {}},
				{"type" : "has_inventory:HasInventory", "params" :  {}},
				{"type" : "has_weapon:HasWeapon", "params" :  {}},
				{"type" : "movable:Movable", "params" :  {"velocity" : 200}},
				{"type" : "collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}},
				{"type" : "camera:Camera", "params" : {"always_center": false, "screen_fill": true}}
			]
		},
		{
			"id" : "iron_arrows_pack",
			"templates" : [
				"model/ammo_pack/shoot/iron_arrows_pack", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(6, 10, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "ammo_pack:AmmoPack", "params" : {"weapon": "bow", "type": "iron_arrows"}}
			]
		},
		{
			"id" : "wooden_arrows_pack",
			"templates" : [
				"model/ammo_pack/shoot/wooden_arrows_pack", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(6, 11, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "ammo_pack:AmmoPack", "params" : {"weapon": "bow", "type": "wooden_arrows"}}
			]
		},
		{
			"id" : "fireball_spell_pack",
			"templates" : [
				"model/ammo_pack/spellcast/fireball_spell_pack", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(6, 12, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "ammo_pack:AmmoPack", "params" : {"weapon": "spell", "type": "fireball"}}
			]
		},
		{
			"id" : "copper_coin",
			"templates" : [
				"model/item/coin/copper_coin", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(6, 13, test_arena_sand)" // position template
			],
			"components" : []
		},
		{
			"id" : "golden_coin",
			"templates" : [
				"model/item/coin/golden_coin", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(6, 14, test_arena_sand)" // position template
			],
			"components" : []
		},
		{	
			"id" : "silver_coin",
			"templates" : [
				"model/item/coin/silver_coin", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(6, 15, test_arena_sand)" // position template
			],
			"components" : []
		},

		{
			"id" : "quiver",
			"templates" : [
				"model/weapon/accessories/quiver", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(5, 12, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type" : "bow",	"max_projectiles" : 5}}
			]
		},
		{
			"id" : "bow_metal_big",
			"templates" : [
				"model/weapon/shoot/bow_metal_big", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(5, 13, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type" : "bow",	"max_projectiles" : 5}},
				{"type" : "sound_fx_on_arm_weapon:SoundFXOnArmWeapon", "params" : {"sound" : "arrow-hit.mp3"}}
			]
		},
		{
			"id" : "bow_recurved_wooden",
			"templates" : [
				"model/weapon/shoot/bow_recurved_wooden", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(5, 14, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type" : "bow",	"max_projectiles" : 5}},
				{"type" : "sound_fx_on_arm_weapon:SoundFXOnArmWeapon", "params" : {"sound" : "arrow-hit.mp3"}}
			]
		},
		{
			"id" : "warhammer",
			"templates" : [
				"model/weapon/slash/warhammer", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(5, 15, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type": "sword", "max_projectiles" : 5}}
			]
		},
		{
			"id" : "axe2",
			"templates" : [
				"model/weapon/slash/axe2", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(5, 16, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type": "sword", "max_projectiles" : 5}}
			]
		},
		{
			"id" : "shovel",
			"templates" : [
				"model/weapon/thrust/shovel", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(5, 17, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type": "spear", "max_projectiles" : 5}}
			]
		}
	],

	// How to handle events
	"handlers": [
		[
			"SCENE_START",
			{
				"id": "ev_scene_start",
				"actions": 	[
					"SCRIPT",
					"show_msg_window", 
					{
						"title": "%filepath",
						"html_text": "<b>Scene ID:</b> %id<br/><b>Title:</b> %title<br/><b>Description:</b> %description<br/><b>Objective:</b> %objective<br/><br/><b>Stats:</b> %stats"
					}
				]
			}
		],
		[
			"WEAPON_ARMED",
			{
				"id": "ev_weapon_armed",
				"actions": 	[
					"SCRIPT",
					"add_msg", 
					{
						"text": "Weapon entity id '%weapon' was armed by '%fighter'."
					}
				]
			}
		]

	]
}