{
	"$schema": "../../../../core/schemas/scene.schema.json",

	// Basic data
	"id" : "test_sensors_01",
	"title" : "Test of Sight sence",
	"description" : "Test CanSee component and sense system",
	"objective" : "POC of the sense system",

	// What scenes need to be loaded before this one
	"prereqs" : [],

	// What objects need to be cleaned first
	"cleanup" : {
		"processors": [],
		"maps": [], 
		"templates": [], 
		"entities": [], 
		"dialogs": [],
		"handlers": []
	},

	// What processors to load
	"processors" : [
		// For commands
		["command_system.generate_command_from_input_processor:GenerateCommandFromInputProcessor", {}],
		["command_system.generate_command_from_brain_processor:GenerateCommandFromBrainProcessor", {}],
		["command_system.perform_command_processor:PerformCommandProcessor", {}],

		// For movement
		["movement_system.perform_movement_processor:PerformMovementProcessor", {}],

		// For animation
		["animation_system.perform_movement_animation_processor:PerformMovementAnimationProcessor", {}],
		["animation_system.perform_idle_animation_processor:PerformIdleAnimationProcessor", {}],
		["animation_system.perform_frame_update_processor:PerformFrameUpdateProcessor", {}],

		// For collisions

		["collision_system:GenerateCollisionsProcessor", {}],
		["collision_system:ResolveCollisionsProcessor", {}],
		["collision_system:ResolveMapCollisionsProcessor", {}],


		// For sight - run once per 10 cycles
		["sensor_system.generate_entities_in_sight_processor:GenerateEntitiesInSightProcessor", {"step": 100}],
		["sensor_system.generate_entities_within_earshot_processor:GenerateEntitiesWithinEarshotProcessor", {"step": 100}],

		// For displaying
		["render_system.perform_clear_window_processor:PerformClearWindowProcessor", {}],
		["render_system.perform_clear_camera_processor:PerformClearCameraProcessor", {}],
		["render_system.perform_scroll_camera_processor:PerformScrollCameraProcessor", {}],
		["render_system.perform_render_map_processor:PerformRenderMapProcessor", {}],
		["render_system.perform_render_model_processor:PerformRenderModelProcessor", {}],
		["render_system.perform_render_debug_info_processor:PerformRenderDebugInfoProcessor", {}],
		["render_system.perform_blit_camera_processor:PerformBlitCameraProcessor", {}],

		// For events processing - display the dialog on the start of the scene - after first game screen is generated
		["event_system.game_events_processor:GameEventsExProcessor", {"process" : ["SCENE_START"]}],

		// Removal of obsolete flags
		["movement_system.remove_flag_do_move_processor:RemoveFlagDoMoveProcessor", {}],
		["collision_system.remove_flag_has_collided_processor:RemoveFlagHasCollidedProcessor", {}]

	],

	// What maps to load
	"maps" : ["test_arena_sand"],

	// What dialogs to load
	"dialogs" : [
		{
			"id" : "dlg_scene_start",
			"templates" : ["basic"],

			"dimensions" : [630, 200],

			"font" : {
				"path" : "small_font.json",
				"size" : 24,
				"color" : "#00FFFF",
				"align" : "LEFT"
				},
		
			"texts" : [
				{
					"text" : "Test no.1 - Demonstration of Sight Sense",
					"position" : [5, 20]
				}
			],
			
			"frames" : [
				{
					"font" : {
						"path" : "small_font.json",
						"size" : 16,
						"color" : "#FFFFFF",
						"align" : "LEFT"
						},

					"texts" : [
						{
							"text" : "Entities are spotted and recorded.",
							"position" : [5, 65]
						}
					]
				},
				{
					"texts" : [
						{
							"text" : "Press Enter to continue ...",
							"position" : [5, 165]
						}
					]
				}
			]
		}
	],

	// What templates to load
	"templates": [],

	// What entities to load
	"entities" : [
		{
			"id" : "player01",
			"templates" : ["model/body/male/human/white"],
			"components" : [
				{"type" : "can_see:CanSee", "params" : {"angle": 120, "distance_px": 300}},
				{"type" : "can_hear:CanHear", "params" : {"distance_px": 350}},

				{
					"type" : "debug:Debug", 
					"params" : {
						"info" : {
							"name" : "PLAYER01",
							"description" : "Player is not corrected by collision from anyone even not LAVA."
						}
					}
				},

				{"type" : "controllable:Controllable", "params" :  {"key_profile" : "DEFAULT",
					"control_cmds" : {
						"LEFT": [["move_dir_add", {"moves" : ["left"]}]],
						"RIGHT": [["move_dir_add", {"moves" : ["right"]}]],
						"UP": [["move_dir_add", {"moves" : ["up"]}]],
						"DOWN": [["move_dir_add", {"moves" : ["down"]}]],
						"ATTACK": []}
					}
				},

				{"type" : "position:Position", "params" : {"x" : 250, "y" : 250, "map" : "test_arena_sand"}},
				{"type" : "movable:Movable", "params" :  {"velocity" : 200}},
				{
					"type" : "collidable:Collidable", 
					"params" :  {
						"x" : 15, "y" : 27, 
						"dx" : 0, "dy" : 8,
						"accept_pos_fix_from_denylist" : [] //["ALL"] // no one can move the player
					}},
				{"type" : "camera:Camera", "params" : {"always_center": false, "screen_fill": true}}
			]
		},
		{
			"id" : "NPC01",
			"templates" : ["model/body/male/skeleton/white"],
			"components" : [
				{
					"type" : "debug:Debug",
					"params" : {
						"info" : { 
							"name" : "NPC01",
							"description" : "NPC01 is not corrected by collision from anyone except the PLAYER01"
						}
					}
				},

				// Move right - left
				{
					"type" : "brain_ai:BrainAI", 
					"params" : {
						"blackboard": {}, 
						"cmd_list": [
							{"line": 0, "type": "Behavior", "command": ["move_to_pos_px", {"pos" : [1000,450]}]},
							{"line": 1, "type": "Behavior", "command": ["move_to_pos_px", {"pos" : [10,450]}]},
							{"line": 2, "type": "Goto", "jmp_to": 0} //repeat
						]
					}
				},

				//{"type" : "camera:Camera", "params" : {"always_center": false, "screen_pos_x" : 0, "screen_pos_y" : 240, "screen_width" : 320, "screen_height" : 240}},

				{"type" : "position:Position", "params" : {"x" : 10, "y" : 450, "map" : "test_arena_sand"}},
				{"type" : "movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "collidable:Collidable", "params" :  {
					"x" : 15, 
					"y" : 27, 
					"dx" : 0, 
					"dy" : 8,
					"accept_pos_fix_from_allowlist" : ["player01"] // only player01 can move me
					}}
			]
		},
		{
			"id" : "NPC02",
			"templates" : ["model/body/male/skeleton/green"],
			"components" : [
				{
					"type" : "debug:Debug",
					"params" : {
						"info" : { 
							"name" : "NPC02"
						}
					}
				},

				// Move up - down
				{
					"type" : "brain_ai:BrainAI", 
					"params" : {
						"blackboard": {}, 
						"cmd_list": [
							{"line": 0, "type": "Behavior", "command": ["move_to_pos_px", {"pos" : [219,10]}]},
							{"line": 1, "type": "Behavior", "command": ["move_to_pos_px", {"pos" : [219,800]}]},
							{"line": 2, "type": "Goto", "jmp_to": 0} //repeat
						]
					}
				},

				{"type" : "position:Position", "params" : {"x" : 219, "y" : 800, "map" : "test_arena_sand"}},
				{"type" : "movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}}
			]
		},
		{
			"id" : "NPC03",
			"templates" : ["model/body/male/skeleton/grey"],
			"components" : [
				{
					"type" : "debug:Debug",
					"params" : {
						"info" : { 
							"name" : "NPC03"
						}
					}
				},

				// Move down - up
				{
					"type" : "brain_ai:BrainAI", 
					"params" : {
						"blackboard": {}, 
						"cmd_list": [
							{"line": 0, "type": "Behavior", "command": ["move_to_pos_px", {"pos" : [319,1000]}]},
							{"line": 1, "type": "Behavior", "command": ["move_to_pos_px", {"pos" : [319,10]}]},
							{"line": 2, "type": "Goto", "jmp_to": 0} //repeat
						]
					}
				},

				{"type" : "position:Position", "params" : {"x" : 319, "y" : 10, "map" : "test_arena_sand"}},
				{"type" : "movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}}
			]
		},
		{
			"id" : "NPC04",
			"templates" : ["model/body/male/zombie/green"],
			"components" : [
				{
					"type" : "debug:Debug",
					"params" : {
						"info" : { 
							"name" : "NPC04"
						}
					}
				},

				// Move left - right
				{
					"type" : "brain_ai:BrainAI", 
					"params" : {
						"blackboard": {}, 
						"cmd_list": [
							{"line": 0, "type": "Behavior", "command": ["move_to_pos_px", {"pos" : [50,500]}]},
							{"line": 1, "type": "Behavior", "command": ["move_to_pos_px", {"pos" : [1000,500]}]},
							{"line": 2, "type": "Goto", "jmp_to": 0} //repeat
						]
					}
				},

				{"type" : "position:Position", "params" : {"x" : 1000, "y" : 500, "map" : "test_arena_sand"}},
				{"type" : "movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}}
			]
		},
		{
			"id" : "NPC05",
			"templates" : ["model/body/male/wolfman/gold"],
			"components" : [
				{
					"type" : "debug:Debug",
					"params" : {
						"info" : { 
							"name" : "NPC05"
						}
					}
				},

				// Move left - right
				{
					"type" : "brain_ai:BrainAI", 
					"params" : {
						"blackboard": {}, 
						"cmd_list": [
							{"line": 0, "type": "Behavior", "command": ["move_to_pos_px", {"pos" : [300,100]}]},
							{"line": 1, "type": "Behavior", "command": ["move_to_pos_px", {"pos" : [100,100]}]},
							{"line": 2, "type": "Goto", "jmp_to": 0} //repeat
						]
					}
				},
				
				{"type" : "movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "position:Position", "params" : {"x" : 100, "y" : 100, "map" : "test_arena_sand"}},
				{"type" : "collidable:Collidable", "params" :  {"x" : 15,
														"y" : 27,
														"dx" : 0,
														"dy" : 8}}
			]
		}
	],

	// How to handle events
	"handlers": [
		[
			"SCENE_START",
			{
				"id" : "ev_scene_start",
				"actions" : [
					"SCRIPT",
					"show_dlg_window",
					{"dialog_id" : "dlg_scene_start", "position" : [5, 5]}
				]
			}
		],
		[
			"SCENE_START",
			{
				"id": "ev_scene_start",
				"actions": 	[
					"SCRIPT",
					"show_msg_window", 
					{
						"title": "%filepath",
						"html_text": "<b>Scene ID:</b> %id<br/><b>Title:</b> %title<br/><b>Description:</b> %description<br/><b>Objective:</b> %objective<br/><br/><b>Stats:</b> %stats"
					}
				]
			}
		]
	]
}