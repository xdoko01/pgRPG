{
	"$schema": "../../../../core/schemas/scene.schema.json",

	// Basic data
	"id" : "test_entity_seen",
	"title" : "Test Enemy in Range",
	"description" : "Test behavior tree checking that enemy is in range (sight, hearing) of the entity",
	"objective" : "POC of the behavior",

	// What quests need to be loaded before this one
	"prereqs" : [],

	// What objects need to be cleaned first
	"cleanup" : {
		"processors": [],
		"maps": [], 
		"templates": [], 
		"entities": [], 
		"dialogs": [],
		"handlers": []
	},

	// What processors to load
	"processors" : [
		// For commands
		["new.command_system.generate_command_from_input_processor:GenerateCommandFromInputProcessor", {}],
		["new.command_system.generate_command_from_btree_processor:GenerateCommandFromBTreeProcessor", {}],
		["new.command_system.perform_command_processor:PerformCommandProcessor", {}],

		// For movement
		["new.movement_system.perform_movement_processor:PerformMovementProcessor", {}],

		// For animation
		["new.animation_system.perform_movement_animation_processor:PerformMovementAnimationProcessor", {}],
		["new.animation_system.perform_idle_animation_processor:PerformIdleAnimationProcessor", {}],
		["new.animation_system.perform_frame_update_processor:PerformFrameUpdateProcessor", {}],

		// For collisions
		["new.collision_system:GenerateCollisionsProcessor", {}],
		["new.collision_system:ResolveCollisionsProcessor", {}],
		["new.collision_system:ResolveMapCollisionsProcessor", {}],

		// For sight - run once per 100 cycles
		["new.sensor_system.generate_entities_in_sight_processor:GenerateEntitiesInSightProcessor", {"step": 100}],

		// For displaying
		["new.render_system.perform_clear_window_processor:PerformClearWindowProcessor", {}],
		["new.render_system.perform_clear_camera_processor:PerformClearCameraProcessor", {}],
		["new.render_system.perform_scroll_camera_processor:PerformScrollCameraProcessor", {}],
		["new.render_system.perform_render_map_processor:PerformRenderMapProcessor", {}],
		["new.render_system.perform_render_model_processor:PerformRenderModelProcessor", {}],
		["new.render_system.perform_render_debug_info_processor:PerformRenderDebugInfoProcessor", {}],
		["new.render_system.perform_blit_camera_processor:PerformBlitCameraProcessor", {}],

		// For events processing - display the dialog on the start of the quest - after first game screen is generated
		["original.game_events_processor:GameEventsExProcessor", {"process" : ["QUEST_START"]}],

		// For clearing of processing of movements and collisions
		["new.movement_system.remove_flag_do_move_processor:RemoveFlagDoMoveProcessor", {}],
		["new.collision_system.remove_flag_has_collided_processor:RemoveFlagHasCollidedProcessor", {}]

	],

	// What maps to load
	"maps" : ["test_arena_sand"],

	// What dialogs to load
	"dialogs" : [
		{
			"id" : "dlg_quest_start",
			"templates" : ["basic"],

			"dimensions" : [630, 200],

			"font" : {
				"path" : "small_font.json",
				"size" : 24,
				"color" : "#00FFFF",
				"align" : "LEFT"
				},
		
			"texts" : [
				{
					"text" : "Test no.1 - Demonstration of Sight Sense",
					"position" : [5, 20]
				}
			],
			
			"frames" : [
				{
					"font" : {
						"path" : "small_font.json",
						"size" : 16,
						"color" : "#FFFFFF",
						"align" : "LEFT"
						},

					"texts" : [
						{
							"text" : "Entities are spotted and recorded.",
							"position" : [5, 65]
						}
					]
				},
				{
					"texts" : [
						{
							"text" : "Press Enter to continue ...",
							"position" : [5, 165]
						}
					]
				}
			]
		}
	],

	// What templates to load
	"templates": [],

	// What entities to load
	"entities" : [
		{
			"id" : "player01",
			"templates" : ["new/model/body/male/human/white"],
			"components" : [
				{"type" : "new.can_see:CanSee", "params" : {"angle": 120, "distance_px": 300}},
				{"type" : "new.debug:Debug", "params" : {}},

				{"type" : "new.controllable:Controllable", "params" :  {"key_profile" : "default",
					"control_cmds" : {
						"left" : [["move_dir_add", {"moves" : ["left"]}]],
						"right": [["move_dir_add", {"moves" : ["right"]}]],
						"up" : [["move_dir_add", {"moves" : ["up"]}]],
						"down" : [["move_dir_add", {"moves" : ["down"]}]],
						"attack" : []}
					}
				},

				{"type" : "new.position:Position", "params" : {"x" : 250, "y" : 250, "map" : "test_arena_sand"}},
				{"type" : "new.movable:Movable", "params" :  {"velocity" : 200}},
				{
					"type" : "new.collidable:Collidable", 
					"params" :  {
						"x" : 15, "y" : 27, 
						"dx" : 0, "dy" : 8,
						"accept_pos_fix_from_denylist" : []//["ALL"] // no one can move the player
					}},
				{"type" : "new.camera:Camera", "params" : {"always_center": false, "screen_pos_x" : 0, "screen_pos_y" : 0, "screen_width" : 640, "screen_height" : 480}}
			]
		},
		{
			"id" : "NPC01",
			"templates" : ["new/model/body/male/skeleton/white"],
			"components" : [
				{"type" : "new.debug:Debug", "params" : {}},

				// When player is spotted, move
				//   RepeatUntilFail
				//			|
				//		Inverter
				//			|
				//		   SEQ
				//	  |-------------|
				// TestEnemySeen    GoTo position

				{
					"type" : "new.btree:BTree", 
					"params" : {
						"blackboard": {
						},
						"tree": {
							"type": "Sequence",
							"name": "Main seq",
							"children": [
								{
									// Save target position
									"type": "Behavior",
									"name": "Save target position",
									"cmd_process": ["btree.bb_set_globals", {"bb_target": [1000, 1000]}]
								},
								{
									"type": "RepeatUntilFail",
									"name": "Check for enemy presence until player01 is present",
									"children": [
										{
											"type": "Inverter",
											"name": "Return Fail if sequence is finished",
											"children": [
												{
													"type": "Sequence",
													"name": "Test if enemy seen and then move to position",
													"children": [
														{
															"type": "Behavior",
															"name": "Test if player01 is seen",
															"cmd_process": [
																"btree.test_entity_seen", {
																		"list_of_enemies": ["player01"], 
																		"distance": 300,
																		"angle": 120,
																		"out_bb_entity": "bb_enemy"
																	}
															]
														},
														{
															"type": "Behavior",
															"name": "Go to predefined position",
															"cmd_process": [
																"btree.move_to_bb_position", {
																	"bb_point": "bb_target", 
																	"bb_entity_pos_comp": "bb_entity_pos_comp",
																	"max_move_time_s": 1000,
																	"change_of_direction_ms": 750
																}
															]
														}
													]
												}
											]
										}
									]
								}
							]
						}
					}
				},

				{"type" : "new.position:Position", "params" : {"x" : 10, "y" : 450, "map" : "test_arena_sand"}},
				{"type" : "new.movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "new.collidable:Collidable", "params" :  {
					"x" : 15, 
					"y" : 27, 
					"dx" : 0, 
					"dy" : 8,
					"accept_pos_fix_from_allowlist" : ["player01"] // only player01 can move me
					}}
			]
		},
		{
			"id" : "NPC02",
			"templates" : ["new/model/body/male/skeleton/green"],
			"components" : [
				{
					"type" : "new.debug:Debug",
					"params" : {
						"info" : { 
							"name" : "NPC02"
						}
					}
				},

				// Move up - down
				{"type" : "new.brain:Brain", "params" : {"commands" : [
					[0, 	"new_move_to", {"x" : 219, "y" : 10}],
					[1, 	"new_move_to", {"x" : 219, "y" : 800}],
					[0, 	"goto", {}]
				]}},

				{"type" : "new.position:Position", "params" : {"x" : 219, "y" : 800, "map" : "test_arena_sand"}},
				{"type" : "new.movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "new.collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}}
			]
		},
		{
			"id" : "NPC03",
			"templates" : ["new/model/body/male/skeleton/grey"],
			"components" : [
				{
					"type" : "new.debug:Debug",
					"params" : {
						"info" : { 
							"name" : "NPC03"
						}
					}
				},

				// Move down - up
				{"type" : "new.brain:Brain", "params" : {"commands" : [
					[0, 	"new_move_to", {"x" : 319, "y" : 1000}],
					[1, 	"new_move_to", {"x" : 319, "y" : 10}],
					[0, 	"goto", {}]
				]}},

				{"type" : "new.position:Position", "params" : {"x" : 319, "y" : 10, "map" : "test_arena_sand"}},
				{"type" : "new.movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "new.collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}}
			]
		},
		{
			"id" : "NPC04",
			"templates" : ["new/model/body/male/zombie/green"],
			"components" : [
				{
					"type" : "new.debug:Debug",
					"params" : {
						"info" : { 
							"name" : "NPC04"
						}
					}
				},

				// Move left - right
				{"type" : "new.brain:Brain", "params" : {"commands" : [
					[0, 	"new_move_to", {"x" : 50, "y" : 500}],
					[1, 	"new_move_to", {"x" : 1000, "y" : 500}],
					[0, 	"goto", {}]
				]}},


				{"type" : "new.position:Position", "params" : {"x" : 1000, "y" : 500, "map" : "test_arena_sand"}},
				{"type" : "new.movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "new.collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}}
			]
		},
		{
			"id" : "NPC05",
			"templates" : ["new/model/body/male/wolfman/gold"],
			"components" : [
				{
					"type" : "new.debug:Debug",
					"params" : {
						"info" : { 
							"name" : "NPC05"
						}
					}
				},

				// Move left - right
				{"type" : "new.brain:Brain", "params" : {"commands" : [
					[0, 	"new_move_to", {"x" : 300, "y" : 100}],
					[1, 	"new_move_to", {"x" : 100, "y" : 100}],
					[0, 	"goto", {}]
				]}},
				
				{"type" : "new.movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "new.position:Position", "params" : {"x" : 100, "y" : 100, "map" : "test_arena_sand"}},
				{"type" : "new.collidable:Collidable", "params" :  {"x" : 15,
														"y" : 27,
														"dx" : 0,
														"dy" : 8}}
			]
		}
	],

	// How to handle events
	"handlers": [
		[
			"QUEST_START",
			{
				"id" : "ev_quest_start",
				"actions" : [
					"SCRIPT",
					"new.show_dlg_window",
					{"dialog_id" : "dlg_quest_start", "position" : [5, 5]}
				]
			}
		],
		[
			"QUEST_START",
			{
				"id": "ev_quest_start",
				"actions": 	[
					"SCRIPT",
					"new.show_msg_window", 
					{
						"title": "%filepath",
						"html_text": "<b>Quest ID:</b> %id<br/><b>Title:</b> %title<br/><b>Description:</b> %description<br/><b>Objective:</b> %objective<br/><br/><b>Stats:</b> %stats"
					}
				]
			}
		]
	]
}