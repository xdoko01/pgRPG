{
	// JSON Schema for validation of the game parameters
	"$schema": "../../../../../core/schemas/scene.schema.json",

	// Basic data
	"id" : "move_between_checkpoints",
	"title" : "Test movement between multiple checkpoints",
	"description" : "Test movement between multiple checkpoints",
	"objective" : "POC of NPC controlled by the script",

	// What quests need to be loaded before this one
	"prereqs" : [],

	// What objects need to be cleaned first
	"cleanup" : {
		"processors": [],
		"maps": [], 
		"templates": [], 
		"entities": [], 
		"dialogs": [],
		"handlers": []
	},

	// What processors to load
	"processors" : [
		// For commands
		["new.command_system.generate_command_from_brain_processor:GenerateCommandFromBrainProcessor", {}],
		["new.command_system.perform_command_processor:PerformCommandProcessor", {}],

		// Calculate path
		["new.command_system.perform_pathfinding_calculation_processor:PerformPathfindingCalculationProcessor", {"max_no_of_calcs": 100}],
		
		// For movement
		["new.movement_system.perform_movement_processor:PerformMovementProcessor", {}],
		
		// For animation
		["new.animation_system.perform_movement_animation_processor:PerformMovementAnimationProcessor", {}],
		["new.animation_system.perform_action_animation_processor:PerformActionAnimationProcessor", {}],
		["new.animation_system.perform_action_idle_animation_processor:PerformActionIdleAnimationProcessor", {}],
		["new.animation_system.perform_idle_animation_processor:PerformIdleAnimationProcessor", {}],
		["new.animation_system.perform_expire_animation_processor:PerformExpireAnimationProcessor", {}],
		["new.animation_system.perform_frame_update_processor:PerformFrameUpdateProcessor", {}],

		// NEW - For projectile data generation
		["new.attack_system.generate_projectile_factory_data_processor:GenerateProjectileFactoryDataProcessor", {}],

		// NEW - For generation of projectile from factory and projectile data
		["new.factory_system.perform_factory_generation_processor:PerformFactoryGenerationProcessor", {}],

		// For destroy
		["new.destroy_system.generate_destroy_on_stopped_movement_processor:GenerateDestroyOnStoppedMovementProcessor", {}],
		["new.destroy_system.perform_destroy_entities_processor:PerformDestroyEntitiesProcessor", {}],


		// For displaying
		["new.render_system.perform_clear_window_processor:PerformClearWindowProcessor", {}],
		["new.render_system.perform_clear_camera_processor:PerformClearCameraProcessor", {}],
		["new.render_system.perform_scroll_camera_processor:PerformScrollCameraProcessor", {}],
		["new.render_system.perform_render_map_processor:PerformRenderMapProcessor", {}],
		["new.render_system.generate_render_data_from_parent_processor:GenerateRenderDataFromParentProcessor", {}],
		["new.render_system.perform_render_model_processor:PerformRenderModelProcessor", {}],
		["new.render_system.perform_render_armed_weapon_processor:PerformRenderArmedWeaponProcessor", {}],
		["new.render_system.perform_render_armed_ammo_processor:PerformRenderArmedAmmoProcessor", {}],
		["new.render_system.perform_render_debug_info_processor:PerformRenderDebugInfoProcessor", {}],
		["new.render_system.perform_blit_camera_processor:PerformBlitCameraProcessor", {}],

		// For events processing - display the dialog on the start of the quest - after first game screen is generated
		["original.game_events_processor:GameEventsExProcessor", {"process" : ["QUEST_START"]}],

		// Removal of obsolete flags
		["new.movement_system.remove_flag_do_move_processor:RemoveFlagDoMoveProcessor", {}],
		["new.attack_system.remove_flag_do_attack_processor:RemoveFlagDoAttackProcessor", {}],
		["new.animation_system.remove_flag_is_animation_action_frame_processor:RemoveFlagIsAnimationActionFrameProcessor", {}],
		["new.factory_system.remove_flag_create_from_factory_processor:RemoveFlagCreateFromFactoryProcessor", {}],
		["new.factory_system.remove_flag_generated_from_factory_processor:RemoveFlagGeneratedFromFactoryProcessor", {}],
		["new.movement_system.remove_flag_has_stopped_movement_processor:RemoveFlagHasStoppedMovementProcessor", {}]
	],

	// What maps to load
	"maps" : ["test_arena_sand"],

	// What dialogs to load
	"dialogs": [],

	// What templates to load
	"templates": [],

	// What entities to load
	"entities" : [
		{
			"id" : "NPC",
			"templates" : [
				"new/model/body/male/wolfman/gold",
				"new/behavior/move_between_2_points($x1=10,$y1=10,$x2=30,$y2=10)" // behavior template
			],
			"components" : [
				{"type" : "new.debug:Debug", "params": {"info": {"name" : "NPC"}}},
				{"type" : "new.movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "new.position:Position", "params" : {"tile_x" : 10, "tile_y" : 10, "map" : "test_arena_sand"}},
				{"type" : "new.collidable:Collidable", "params" :  {"x": 15, "y": 27, "dx": 0, "dy": 8}}
			]
		},

		{
			"id" : "wooden_bow",
			"templates" : ["new/model/weapon/shoot/bow_wooden_big"],
			"components" : [
				{"type" : "new.weapon:Weapon", "params" : {"type" : "bow",	"max_projectiles" : 5}}
			]
		},

		// wooden_arrows_pack AmmoPack is Factory for generation of arrows
		{
			"id" : "wooden_arrows_pack",
			"templates" : ["new/model/ammo_pack/shoot/wooden_arrows_pack"],
			"components" : [
				{"type" : "new.ammo_pack:AmmoPack", "params" : {"weapon" : "bow", "type" : "wooden_arrows_pack"}},
				{
					"type" : "new.factory:Factory", 
					"params" : {
						"prescription" : {
							"id": "wooden_arrows_pack_arrow",
							"templates" : ["new/model/ammo/shoot/wooden_arrow"],
							"components" : [
								{"type" : "new.debug:Debug", "params" : {}},
								
								{
									"type" : "new.brain_ai:BrainAI",
									"params" : {
										"cmd_list" : [
											{"command": ["move_auto", {}]} // duration is not specified so the movement is infinite
										]
									}
								},
				
								//{"type" : "new.damaging:Damaging", "params" : {"damage" : 25}},

								{"type" : "new.movable:Movable", "params" :  {"velocity" : 300, "accelerate" : -3}},
								//{"type" : "new.collidable:Collidable", "params" : {"x" : 8, "y" : 8, "accept_pos_fix_from_denylist" : ["ALL"]}},
								//{"type" : "new.destroy_on_collision:DestroyOnCollision", "params" : {"ttl" : 0}},
								{"type" : "new.destroy_on_no_movement:DestroyOnNoMovement", "params" : {"ttl" : 0}}
								
								//{"type" : "new.visual_fx_on_collision:VisualFXOnCollision", "params" : {"effect" : "new/effects/explosion"}},
								//{"type" : "new.sound_fx_on_collision:SoundFXOnCollision", "params" : {"sound" : "hurt/1.mp3"}}
							]
						}
					}
				}
			]
		},

		{
			"id" : "player01",
			"templates" : ["new/model/body/male/human/brown"],
			"components" : [
				{"type" : "new.debug:Debug", "params" : {}},

				{"type" : "new.has_weapon:HasWeapon", "params" : {
					"weapons" : {
						"bow" : {"weapon" : "wooden_bow", "generator" : "wooden_arrows_pack"}
					}
				}},

				{"type" : "new.weapon_in_use:WeaponInUse", "params" :  {"type" : "bow"}},

				{
					"type" : "new.brain_ai:BrainAI", 
					"params" : {

						"blackboard": {
							"checkpoints": [[5,5], [50,50], [50,5]]
						}, 

						
						
						"cmd_tree": {
							"type": "Repeater",
							"name": "Repeat Movement among the checkpoints",
							"children": [
								{
									"type": "Sequence",
									"name": "Move between Checkpoints",
									"children": [
										{"name": "Move to checkpoints", "type": "Behavior", "command": ["move_to_checkpoints", {"checkpoints": "^checkpoints"}]}
									]
								}
							]
						}
					}
				},

				{"type" : "new.position:Position", "params" : {"tile_x": 5, "tile_y": 5, "map" : "test_arena_sand"}},
				{"type" : "new.movable:Movable", "params" :  {"velocity" : 100}},
				{"type" : "new.camera:Camera", "params" : {"always_center": false, "screen_pos_x" : 0, "screen_pos_y" : 0, "screen_width" : 640, "screen_height" : 480}}
			]
		}
	],

	// How to handle events
	"handlers": [
		[
			"QUEST_START",
			{
				"id": "ev_quest_start",
				"actions": 	[
					"SCRIPT",
					"new.show_msg_window", 
					{
						"title": "%filepath",
						"html_text": "<b>Quest ID:</b> %id<br/><b>Title:</b> %title<br/><b>Description:</b> %description<br/><b>Objective:</b> %objective<br/><br/><b>Stats:</b> %stats"
					}
				]
			}
		]
	]
}