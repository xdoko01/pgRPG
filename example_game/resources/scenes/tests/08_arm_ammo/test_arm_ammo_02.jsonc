{
	// JSON Schema for validation of the game parameters
	"$schema": "../../../../core/schemas/scene.schema.json",

	// Basic data
	"id" : "test_arm_ammo_02",
	"title" : "Arming ammo using action key on AmmoPack/Factory in inventory window",
	"description" : "Arming ammo using action key on AmmoPack in inventory window - using inventory_action command",
	"objective" : "POC of arming through inventory",

	// What scenes need to be loaded before this one
	"prereqs" : [],

	// What objects need to be cleaned first
	"cleanup" : {
		"processors": [],
		"maps": [], 
		"templates": [], 
		"entities": [], 
		"dialogs": [],
		"handlers": []
	},

	// What processors to load
	"processors" : [

	//////////////////////////
	// Default processor group
	//////////////////////////

		// For commands
		["command_system:GenerateCommandFromInputProcessor", {}], // cmds from keyboard controlls
		["command_system:GenerateCommandFromBrainProcessor", {}], // cmds from command generators such as behavior trees
		["command_system:GenerateCommandFromMouseProcessor", {}], // cmds from mouse controlls
		["command_system:PerformCommandProcessor", {}], // process the command queue

		// For movement
		["movement_system:PerformMovementProcessor", {}],

		// For animation
		["animation_system:PerformMovementAnimationProcessor", {}],
		["animation_system:PerformActionAnimationProcessor", {}], // once WeaponInUse component is used, this processor must be present
		["animation_system:PerformActionIdleAnimationProcessor", {}], // once WeaponInUse component is used, this processor must be present
		["animation_system:PerformIdleAnimationProcessor", {}],
		["animation_system:PerformExpireAnimationProcessor", {}], // once IsDestroyed component is used, this processor must be present
		["animation_system:PerformFrameUpdateProcessor", {}],

		// For collisions
		["collision_system:GenerateCollisionsProcessor", {}],
		["collision_system:ResolveCollisionsProcessor", {}],

		// For pickup
		["pickup_system:GeneratePickupProcessor", {}],
		["pickup_system:PerformPickupProcessor", {}],

		// For Arming of a Weapon
		["arm_weapon_system:GenerateArmWeaponProcessor", {}], // Following processor commented out for manual arming of the weapon and not automatic during pickup
		["arm_weapon_system:PerformArmWeaponProcessor", {}],
		["effects_system:GenerateSoundFXOnArmWeaponProcessor", {}], // For arming sound effects

		// For Arming of an Ammo
		["arm_ammo_system:GenerateArmAmmoProcessor", {}],
		["arm_ammo_system:PerformArmAmmoProcessor", {}],

		// For dropping 
 		["drop_system:PerformDropProcessor", {}],

		// For Disarming of a weapon
		["arm_weapon_system:GenerateDisarmWeaponProcessor", {}],
		["arm_weapon_system:PerformDisarmWeaponProcessor", {}],

		// For Disarming of an Ammo
		["arm_ammo_system:GenerateDisarmAmmoProcessor", {}],
		["arm_ammo_system:PerformDisarmAmmoProcessor", {}],

		// For setting armed weapon into Use
		["arm_weapon_system:PerformSetWeaponIntoUseProcessor", {}],

		// For displaying
		["render_system:PerformClearWindowProcessor", {}],
		["render_system:PerformClearCameraProcessor", {}],
		["render_system:PerformScrollCameraProcessor", {}],
		["render_system:PerformRenderMapProcessor", {}],
		["render_system:GenerateRenderDataFromParentProcessor", {}],
		["render_system:PerformRenderModelProcessor", {}],
		["render_system:PerformRenderArmedWeaponProcessor", {}],
		["render_system:PerformRenderArmedAmmoProcessor", {}],
		["render_system:PerformRenderDebugInfoProcessor", {}], // for debug info about entities
		["render_system:PerformRenderInventoryProcessor", {}], // for showing inventory window
		["render_system:PerformBlitCameraProcessor", {}], // blitting cameras
		["render_system:PerformRenderMessagesProcessor", {}], // blitting messages

		// For events processing
		["event_system:GameEventsExProcessor", {"process" : ["SCENE_START", "WEAPON_ARMED","AMMO_PACK_ARMED"]}],

		// For clearing of components (usually Flags) at the end of each cycle
		["movement_system:RemoveFlagDoMoveProcessor", {}],
		["collision_system:RemoveFlagHasCollidedProcessor", {}],
		["attack_system:RemoveFlagDoAttackProcessor", {}], // if attack command is used, this processor must be planned. Otherwise no movement will happen after pressing the attack button
		["animation_system:RemoveFlagIsAnimationActionFrameProcessor", {}],

		["pickup_system:RemoveFlagIsAboutToPickEntityProcessor", {}],
		["pickup_system:RemoveFlagHasPickedProcessor", {}],
		["pickup_system:RemoveFlagWasPickedByProcessor", {}],
			
		["arm_weapon_system:RemoveFlagIsAboutToArmWeaponProcessor", {}],
		["arm_weapon_system:RemoveFlagHasArmedWeaponProcessor", {}],
		["arm_weapon_system:RemoveFlagWasArmedAsWeaponByProcessor", {}],

		["arm_ammo_system:RemoveFlagIsAboutToArmAmmoProcessor", {}],
		["arm_ammo_system:RemoveFlagHasArmedAmmoProcessor", {}],
		["arm_ammo_system:RemoveFlagWasArmedAsAmmoByProcessor", {}],

		["drop_system:RemoveFlagIsAboutToDropEntityProcessor", {}],
		["drop_system:RemoveFlagHasDroppedProcessor", {}],
		["drop_system:RemoveFlagWasDroppedByProcessor", {}],

		["arm_weapon_system:RemoveFlagIsAboutToDisarmWeaponProcessor", {}],
		["arm_weapon_system:RemoveFlagHasDisarmedWeaponProcessor", {}],
		["arm_weapon_system:RemoveFlagWasDisarmedAsWeaponByProcessor", {}],

		["arm_ammo_system:RemoveFlagIsAboutToDisarmAmmoProcessor", {}],
		["arm_ammo_system:RemoveFlagHasDisarmedAmmoProcessor", {}],
		["arm_ammo_system:RemoveFlagWasDisarmedAsAmmoByProcessor", {}],


	//////////////////////////
	// Pause processor group - initiated by pressing 'P' button
	//////////////////////////
			["pause", "render_system.perform_blit_picture_processor:PerformBlitPictureProcessor", {"filepath": "pause.png", "resize": true}]
	],
	
	// What maps to load
	"maps" : ["test_arena_sand"],

	// What dialogs to load
	"dialogs" : [],

	// What templates to load
	"templates": [
		// By using template with parameters it is easy to define position of any entity
		{
			"id": "t_tile_pos",
			"vars": ["$tileX", "$tileY", "$map"],
			"components": [
				{"type" : "position:Position", "params" : {"tile_x" : "$tileX", "tile_y" : "$tileY", "map" : "$map"}}
			]
		},
		{
			"id" : "t_pickable_item",
			"components" : [
				{"type" : "debug:Debug", "params" : {}},
				{"type" : "pickable:Pickable", "params" :  {}},
				{"type" : "collidable:Collidable", "params" :  {"x" : 15, "y" : 15, "dx" : 0, "dy" : 8}}
			]
		}
	],

	// What entities to load
	"entities" : [
		{
			"id" : "player01",
			"templates" : [
				"model/body/male/skeleton/white", // model template
				"controls/game_default",   // controls template
				"t_tile_pos(5, 5, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "debug:Debug", "params" : {}},
				{"type" : "has_inventory:HasInventory", "params" :  {}},
				{"type" : "has_weapon:HasWeapon", "params" :  {}},
				{"type" : "movable:Movable", "params" :  {"velocity" : 200}},
				{"type" : "collidable:Collidable", "params" :  {"x" : 15, "y" : 27, "dx" : 0, "dy" : 8}},
				{"type" : "camera:Camera", "params" : {"always_center": false, "screen_fill": true}}
			]
		},
		{
			"id" : "w_crossbow",
			"templates" : [
				"thing/ammo_pack/thrust/crossbow_arrows_pack($arrows_count=100)", // ammo pack
				"thing/weapon/spear/crossbow", // weapon must be second to overwrite the renderable model of ammo pack
				"t_tile_pos(7, 5, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "debug:Debug", "params" : {}}
			]
		},
		//{
		//	"id" : "w_crossbow",
		//	"templates" : [
		//		"model/weapon/thrust/crossbow", // model template
		//		"t_pickable_item", // pickable template
		//		"t_tile_pos(7, 7, test_arena_sand)" // position template
		//	],
		//	"components" : [
		//		{"type" : "weapon:Weapon", "params" : {"type" : "spear",	"max_projectiles" : 5}},
		//		{"type" : "sound_fx_on_arm_weapon:SoundFXOnArmWeapon", "params" : {"sound" : "arrow-hit.mp3"}}
		//	]
		//},

		{
			"id" : "iron_arrows_pack",
			"templates" : [
				["thing/ammo_pack/shoot/iron_arrows_pack", { "$arrows_count": 10}],
				"t_tile_pos(6, 10, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "debug:Debug", "params" : {}}
			]
		},

		//{
		//	"id" : "iron_arrows_pack",
		//	"templates" : [
		//		"model/ammo_pack/shoot/iron_arrows_pack", // model template
		//		"t_pickable_item", // pickable template
		//		"t_tile_pos(6, 10, test_arena_sand)" // position template
		//	],
		//	"components" : [
		//		{"type" : "ammo_pack:AmmoPack", "params" : {"weapon": "bow", "type": "iron_arrows"}},
		//		{
		//			"type" : "factory:Factory", 
		//			"params" : {
		//				"max_units" : 5,
		//				"prescription" : {
		//					"templates" : ["model/ammo/shoot/iron_arrow"],
		//					"components" : [
		//						{"type" : "debug:Debug", "params" : {}}
		//					]
		//				} 
		//			}
		//		}
		//	]
		//},

		{
			"id" : "wooden_arrows_pack",
			"templates" : [
				"model/ammo_pack/shoot/wooden_arrows_pack", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(6, 11, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "ammo_pack:AmmoPack", "params" : {"weapon": "bow", "type": "wooden_arrows"}},
				{
					"type" : "factory:Factory", 
					"params" : {
						"max_units" : 5,
						"prescription" : {
							"templates" : ["model/ammo/shoot/wooden_arrow"],
							"components" : [
								{"type" : "debug:Debug", "params" : {}}
							]
						} 
					}
				}
			]
		},
		{
			"id" : "fireball_spell_pack",
			"templates" : [
				"model/ammo_pack/spellcast/fireball_spell_pack", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(6, 12, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "ammo_pack:AmmoPack", "params" : {"weapon": "spell", "type": "fireball"}},
				{"type" : "weapon:Weapon", "params" : {"type" : "spell",	"max_projectiles" : 5}},
				{
					"type" : "factory:Factory", 
					"params" : {
						"max_units" : 5,
						"prescription" : {
							"components" : [
								{"type" : "debug:Debug", "params" : {}}
							]
						} 
					}
				}
			]
		},
		{
			"id" : "copper_coin",
			"templates" : [
				"model/item/coin/copper_coin", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(6, 13, test_arena_sand)" // position template
			],
			"components" : []
		},
		{
			"id" : "golden_coin",
			"templates" : [
				"model/item/coin/golden_coin", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(6, 14, test_arena_sand)" // position template
			],
			"components" : []
		},
		{	
			"id" : "silver_coin",
			"templates" : [
				"model/item/coin/silver_coin", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(6, 15, test_arena_sand)" // position template
			],
			"components" : []
		},

		{
			"id" : "quiver",
			"templates" : [
				"model/weapon/accessories/quiver", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(5, 12, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type" : "bow",	"max_projectiles" : 5}}
			]
		},
		{
			"id" : "bow_metal_big",
			"templates" : [
				"model/weapon/shoot/bow_metal_big", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(5, 13, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type" : "bow",	"max_projectiles" : 5}},
				{"type" : "sound_fx_on_arm_weapon:SoundFXOnArmWeapon", "params" : {"sound" : "arrow-hit.mp3"}}
			]
		},
		{
			"id" : "bow_recurved_wooden",
			"templates" : [
				"model/weapon/shoot/bow_recurved_wooden", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(5, 14, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type" : "bow",	"max_projectiles" : 5}},
				{"type" : "sound_fx_on_arm_weapon:SoundFXOnArmWeapon", "params" : {"sound" : "arrow-hit.mp3"}}
			]
		},
		{
			"id" : "warhammer",
			"templates" : [
				"model/weapon/slash/warhammer", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(5, 15, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type": "sword", "max_projectiles" : 5}}
			]
		},
		{
			"id" : "axe2",
			"templates" : [
				"model/weapon/slash/axe2", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(5, 16, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type": "sword", "max_projectiles" : 5}}
			]
		},
		{
			"id" : "shovel",
			"templates" : [
				"model/weapon/thrust/shovel", // model template
				"t_pickable_item", // pickable template
				"t_tile_pos(5, 17, test_arena_sand)" // position template
			],
			"components" : [
				{"type" : "weapon:Weapon", "params" : {"type": "spear", "max_projectiles" : 5}}
			]
		}
	],

	// How to handle events
	"handlers": [
		[
			"SCENE_START",
			{
				"id": "ev_scene_start",
				"actions": 	[
					"SCRIPT",
					"show_msg_window", 
					{
						"title": "%filepath",
						"html_text": "<b>Scene ID:</b> %id<br/><b>Title:</b> %title<br/><b>Description:</b> %description<br/><b>Objective:</b> %objective<br/><br/><b>Stats:</b> %stats"
					}
				]
			}
		],
		[
			"WEAPON_ARMED",
			{
				"id": "ev_weapon_armed",
				"actions": 	[
					"SCRIPT",
					"add_msg", 
					{
						"text": "Weapon entity id '%weapon' was armed by '%fighter'."
					}
				]
			}
		],
		[
			"AMMO_PACK_ARMED",
			{
				"id": "ev_ammo_pack_armed",
				"actions" : [
					"SCRIPT",
					"add_msg", 
					{
						"text": "Ammo '%ammo' was armed by '%fighter'."
					}
				]
			}
		]
	]
}