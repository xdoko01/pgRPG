{
	"$schema": "../../../../../core/schemas/new/scene.schema.json",

	// Basic data
	"id" : "q_kill_all",
	"title" : "Kill All Game Demo",
	"description" : "Game where your objective is to kill all the enemies",
	"objective" : "Kill all your enemies",

	// What scenes need to be loaded before this one
	"prereqs" : [],

	// What objects need to be cleaned first
	"cleanup" : {
		"processors": [],
		"maps": [], 
		"templates": [], 
		"entities": [], 
		"dialogs": [],
		"handlers": []
	},

	// What processors to load
	"processors" : [

		// For events processing
		["event_system.game_events_processor:GameEventsExProcessor", {"process" : ["QUEST_START", "DESTROYED", "CUST_UI_CONFIRM"]}],

		// For commands
		["command_system.generate_command_from_input_processor:GenerateCommandFromInputProcessor", {}],
		["command_system.generate_command_from_brain_processor:GenerateCommandFromBrainProcessor", {}],
		["command_system.generate_command_from_btree_processor:GenerateCommandFromBTreeProcessor", {}],
		["command_system.perform_command_processor:PerformCommandProcessor", {}],

		// For movement - projectile must have FlagDoMove in order to move and not fail to idle
		// ideally if some command can be in place to tell him to move in his brain - new_move_auto command
		["movement_system.perform_movement_processor:PerformMovementProcessor", {"step": 1}],

		// For animation
		["animation_system.perform_movement_animation_processor:PerformMovementAnimationProcessor", {}],
		["animation_system.perform_action_animation_processor:PerformActionAnimationProcessor", {}],
		["animation_system.perform_action_idle_animation_processor:PerformActionIdleAnimationProcessor", {}],
		["animation_system.perform_idle_animation_processor:PerformIdleAnimationProcessor", {}],
		["animation_system.perform_expire_animation_processor:PerformExpireAnimationProcessor", {}],
		["animation_system.perform_frame_update_processor:PerformFrameUpdateProcessor", {}],

		// For projectile data generation
		["attack_system.generate_projectile_factory_data_processor:GenerateProjectileFactoryDataProcessor", {}],

		// For generation of projectile from factory and projectile data
		["factory_system.perform_factory_generation_processor:PerformFactoryGenerationProcessor", {}],

		// Adjust collision component of the entity - mainly for factory generated entities
		["collision_system.perform_adjust_collidable_processor:PerformAdjustCollidableProcessor", {}],

		// Adjust movable component of the entity - mainly for factory generated entities
		["movement_system.perform_adjust_movement_processor:PerformAdjustMovementProcessor", {}],

		// Adjust damaging component of the entity - mainly for factory generated entities
		["damage_system.perform_adjust_damaging_processor:PerformAdjustDamagingProcessor", {}],

		// For collisions
		["collision_system:GenerateCollisionsProcessor", {}],
		["collision_system:ResolveCollisionsProcessor", {}],
		
		// For damages
		["damage_system:GenerateDamageProcessor", {}],
		["damage_system:PerformDamageProcessor", {}],

		// For destroy
		["destroy_system.generate_destroy_on_collision_processor:GenerateDestroyOnCollisionProcessor", {}],
		["destroy_system.generate_destroy_on_stopped_movement_processor:GenerateDestroyOnStoppedMovementProcessor", {}],
		["destroy_system.generate_destroy_on_no_health_processor:GenerateDestroyOnNoHealthProcessor", {}],

		["destroy_system.perform_destroy_entities_processor:PerformDestroyEntitiesProcessor", {}],

		// For sight
		["sensor_system.generate_entities_in_sight_processor:GenerateEntitiesInSightProcessor", {}],

		// For visual and sound effects
		["effects_system.generate_visual_fx_on_collision_processor:GenerateVisualFXOnCollisionProcessor", {}],
		["effects_system.generate_sound_fx_on_collision_processor:GenerateSoundFXOnCollisionProcessor", {}],

		// For displaying on screen
		["render_system.perform_clear_window_processor:PerformClearWindowProcessor", {}],
		["render_system.perform_clear_camera_processor:PerformClearCameraProcessor", {}],
		["render_system.perform_scroll_camera_processor:PerformScrollCameraProcessor", {}],
		["render_system.perform_render_map_processor:PerformRenderMapProcessor", {}],
		["render_system.generate_render_data_from_parent_processor:GenerateRenderDataFromParentProcessor", {}],
		["render_system.perform_render_model_processor:PerformRenderModelProcessor", {}],
		["render_system.perform_render_armed_weapon_processor:PerformRenderArmedWeaponProcessor", {}],
		["render_system.perform_render_armed_ammo_processor:PerformRenderArmedAmmoProcessor", {}],
		["render_system.perform_render_debug_info_processor:PerformRenderDebugInfoProcessor", {}],
		["render_system.perform_blit_camera_processor:PerformBlitCameraProcessor", {}],

		// Removals
		["movement_system.remove_flag_do_move_processor:RemoveFlagDoMoveProcessor", {}],
		["movement_system.remove_flag_adjust_movement_processor:RemoveFlagAdjustMovementProcessor", {}],
		["movement_system.remove_flag_has_stopped_movement_processor:RemoveFlagHasStoppedMovementProcessor", {}],

		["collision_system.remove_flag_has_collided_processor:RemoveFlagHasCollidedProcessor", {}],
		["collision_system.remove_flag_adjust_collidable_processor:RemoveFlagAdjustCollidableProcessor", {}],
		["attack_system.remove_flag_do_attack_processor:RemoveFlagDoAttackProcessor", {}],
		["animation_system.remove_flag_is_animation_action_frame_processor:RemoveFlagIsAnimationActionFrameProcessor", {}],
		["factory_system.remove_flag_create_from_factory_processor:RemoveFlagCreateFromFactoryProcessor", {}],
		["factory_system.remove_flag_generated_from_factory_processor:RemoveFlagGeneratedFromFactoryProcessor", {}],

		["damage_system.remove_flag_is_about_to_be_damaged_by_processor:RemoveFlagIsAboutToBeDamagedByProcessor", {}],
		["damage_system.remove_flag_was_damaged_by_processor:RemoveFlagWasDamagedByProcessor", {}],
		["damage_system.remove_flag_has_damaged_processor:RemoveFlagHasDamagedProcessor", {}],
		["damage_system.remove_flag_adjust_damaging_processor:RemoveFlagAdjustDamagingProcessor", {}],
		["damage_system.remove_flag_has_no_health_processor:RemoveFlagHasNoHealthProcessor", {}]

	],

	// What maps to load
	"maps" : [],
			
	// What dialogs to load
	"dialogs": [],

	// What templates to load
	"templates": [
				
		// By using template with parameters it is easy to define position of any entity
		{
			"id": "t_tile_pos",
			"vars": ["$tileX", "$tileY", "$map"],
			"components": [
				{"type" : "position:Position", "params" : {"tile_x" : "$tileX", "tile_y" : "$tileY", "map" : "$map"}}
			]
		}

	],

	// How to handle events
	"handlers" : [
		[
			"QUEST_START",
			{
				"id": "h_start_game",
				
				"actions": [
					"SEQ",
					["SCRIPT", "load_image", {"image_file" : "weather_effects/rainy/frame_00_delay-0.06s.gif"}],
					["SCRIPT", "show_msg_window", {"html_text" : "Welcome to the <b>%scene_id</b> scene.<br/>Your goal is to kill all the enemies.<br/><br/>Good luck!"}],
					["SCRIPT", "load_quest", {"scene_file" : "new/games/kill_all/kill_all_level01.json"}]
				]
			}
		]
	]
}