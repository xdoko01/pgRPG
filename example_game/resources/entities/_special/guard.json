{
"id": "t_guard",
"vars": ["$path_in", "$list_of_enemies_in"],
"components": [
        {
            "type" : "btree:BTree", 
            "params" : {
                "blackboard": {
                },
                "tree": {
                    // Guard path and attack intruder
                    "type": "Sequence",
                    "name": "Guard",
                    "children": [
                        //{
                        //    // Save my position component ref on bb
                        //    "type": "Behavior",
                        //    "name": "Save My Position Component",
                        //    "cmd_process": ["btree.bb_set_comp_globals", {"bb_key": "bb_entity_pos_comp", "component": "position:Position"}]
                        //},
                        {
                            // Save my position component ref on bb
                            "type": "Behavior",
                            "name": "Save My Position Component",
                            "cmd_process": [
                                "btree.bb_set_comps_globals", 
                                {
                                    "components": [
                                        {
                                            "bb_key": "bb_entity_pos_comp",
                                            "component": "position:Position"
                                        }
                                    ]
                                }
                            ]
                        },

                        {
                            // GUard the path until player01 is spotted
                            "type": "TemplateTree",
                            "name": "Guard Path",
                            "template": [
                                "guard_path", 
                                {
                                    "$bb_entity_pos_comp_in": "bb_entity_pos_comp",
                                    "$path_in": "$path_in",
                                    "$repeat_path_in": true,
                                    "$list_of_enemies_in": "$list_of_enemies_in",
                                    "$guard_radius_in": 400,
                                    "$bb_enemy_out": "bb_target_entity"
                                }
                            ]
                        },
                        {
                            "type": "TemplateTree",
                            "name": "Destroy Target",
                            "template": [
                                "destroy_target",
                                {
                                    "$bb_entity_pos_comp_in": "bb_entity_pos_comp",
                                    "$target_in": "bb_target_entity",
                                    "$attack_time_ms_in": 750
                                }
                            ]
                        }
                    ]
                }
            }
        }
    ]
}