{
    "type": "RepeatUntilFail",
    "name": "Repeat Seak and Attack Until Possible",
    "vars": ["$bb_entity_pos_comp_in", "$target_in", "$range_in=150", "$get_target_pos_ms_in=1200", "$hunt_time_in=999", "$attack_time_ms_in"],
    "children": [
        {
            // Attack till death
            "type": "Sequence",
            "name": "Seek and Attack",
            "children": [
                {
                    // Get close to the target in order to be able to attack
                    "type": "Sequence",
                    "name": "Move To Target",
                    "children": [
                        {
                            // Save target position component ref on bb
                            "type": "Behavior",
                            "name": "Save Target Position Component",
                            "command": ["btree.bb_set_comp_globals", {"bb_key": "bb_target_pos_comp", "bb_entity": "$target_in", "component": "position:Position"}]
                        },
                        {
                            // Move to the close range to the target
                            "type": "Behavior",
                            "name": "Move to the target",
                            "command": [
                                "btree.move_to_target_range", 
                                {
                                    "target_pos_comp": "bb_target_pos_comp", 
                                    "entity_pos_comp": "$bb_entity_pos_comp_in",
                                    "range": "$range_in",
                                    "get_target_position_ms": "$get_target_pos_ms_in", // the shorter the time the better opponent
                                    "max_hunt_time_s": "$hunt_time_in"	// stop the hunt if not reached in those sec duration
                                }
                            ]
                        }
                    ]
                },
                {
                    // Attack the target
                    "type": "Sequence",
                    "name": "Attack Target",
                    "children": [
                        {
                            // Save entity damagable component
                            "type": "Behavior",
                            "name": "Save My Damagable Component",
                            "command": ["btree.bb_set_comp_globals", {"bb_key": "bb_entity_damageable_comp", "component": "damageable:Damageable"}]
                        },
                        {
                            // Save target damagable component
                            "type": "Behavior",
                            "name": "Save Target Damageable Component",
                            "command": ["btree.bb_set_comp_globals", {"bb_key": "bb_target_damageable_comp", "bb_entity": "$target", "component": "damageable:Damageable"}]
                        },
                        {
                            // Attack
                            "type": "Behavior",
                            "name": "Attack the target",
                            "command": [
                                "btree.attack_full", 
                                {
                                    "target_damageable_comp": "bb_target_damageable_comp", 
                                    "entity_damageable_comp": "bb_entity_damageable_comp",
                                    "attack_time_ms": "$attack_time_ms_in"
                                }
                            ]
                        }
                    ]
                }
            ]
        }
    ]
}